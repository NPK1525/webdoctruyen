@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bảng Quản Trị - MangaNPK</title>
    <link rel="stylesheet" href="/css/style.css?v=3.0" />
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body>
    <div id="root">

      <!-- Global Sticky Header -->
      <header id="global-header" class="glass" style="position: sticky; top: 0; z-index: 1000;">
        <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 70px;">
          <div style="display: flex; align-items: center; gap: 15px;">
            <button id="sidebar-toggle-btn" style="color: var(--text-main); display: flex; align-items: center; cursor: pointer; background: none; border: none;" title="Menu">
              <i data-lucide="menu" style="width: 24px; height: 24px;"></i>
            </button>
            <div id="logo-btn" style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
              <div style="width: 38px; height: 38px; border-radius: 8px; background-color: #FF8C00; display: flex; align-items: center; justify-content: center;">
                <i data-lucide="book-open" style="width: 20px; height: 20px; color: white;"></i>
              </div>
              <span style="font-size: 1.35rem; font-weight: 800; letter-spacing: -0.02em; color: white;">
                Manga<span style="color: #FF8C00;">NPK</span>
              </span>
            </div>
            <div style="width: 1px; height: 20px; background-color: rgba(255,255,255,0.1); margin: 0 10px;"></div>
            <span style="font-size: 0.95rem; font-weight: 700; color: #FF4552; text-transform: uppercase; letter-spacing: 0.05em;">Admin Control Panel</span>
          </div>
          <div id="header-user-area" style="display: flex; align-items: center; gap: 15px;"></div>
        </div>
      </header>

      @await Html.PartialAsync("_Sidebar")
      @await Html.PartialAsync("_AuthModal")

      <!-- Main Layout -->
      <main id="main-layout" style="flex: 1; display: flex; flex-direction: column; width: 100%; margin-top: 24px; margin-bottom: 50px;">
        <div class="container">

          <!-- Access denied -->
          <div id="admin-access-denied" class="glass-card" style="padding: 40px; text-align: center; border-radius: var(--radius-lg); margin-top: 30px; display: none;">
            <i data-lucide="alert-circle" style="width: 48px; height: 48px; color: #FF4552; margin-bottom: 16px;"></i>
            <h2 style="font-size: 1.5rem; font-weight: 800; color: white; margin-bottom: 10px;">Truy Cập Bị Từ Chối</h2>
            <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 24px;">Bạn cần đăng nhập bằng tài khoản Admin để truy cập.</p>
            <a href="/" class="btn btn-primary" style="border-radius: 20px;">Về trang chủ</a>
          </div>

          <!-- Admin Panel -->
          <div id="admin-panel-wrapper" style="display: none;">
            <div style="display: flex; gap: 30px; flex-wrap: wrap;">

              <!-- Left: Tab nav -->
              <div style="width: 250px; flex-shrink: 0; display: flex; flex-direction: column; gap: 6px;">
                <h4 style="font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; padding: 10px 16px; margin: 0;">Quản lý</h4>
                <button class="admin-tab-btn active" data-tab="manga-list" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="book-open" style="width: 18px; height: 18px;"></i><span>Danh sách truyện</span>
                </button>
                <button class="admin-tab-btn" data-tab="manga" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="plus" style="width: 18px; height: 18px;"></i><span id="tab-label-manga-form">Đăng truyện mới</span>
                </button>
                <button class="admin-tab-btn" data-tab="chapter" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="layers" style="width: 18px; height: 18px;"></i><span>Thêm chương mới</span>
                </button>
                <button class="admin-tab-btn" data-tab="author" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="users" style="width: 18px; height: 18px;"></i><span>Quản lý tác giả</span>
                </button>
                <button class="admin-tab-btn" data-tab="genre" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="tag" style="width: 18px; height: 18px;"></i><span>Quản lý thể loại</span>
                </button>
              </div>

              <!-- Right: Content -->
              <div style="flex: 1; min-width: 320px;">
                <div class="glass-card" style="padding: 30px; border-radius: var(--radius-lg);">

                  <div id="admin-toast-message" style="display: none; padding: 12px 16px; border-radius: 6px; margin-bottom: 24px; font-size: 0.85rem; align-items: center; gap: 8px;">
                    <i data-lucide="check" class="icon-success" style="width: 16px; height: 16px; display: none;"></i>
                    <i data-lucide="alert-circle" class="icon-error" style="width: 16px; height: 16px; display: none;"></i>
                    <span class="msg-text">Hoạt động thành công.</span>
                  </div>

                  <!-- Manga List -->
                  <div id="adm-content-manga-list" class="admin-tab-pane">
                    <h3 style="font-size: 1.25rem; font-weight: 800; color: white; margin-bottom: 20px;">Danh Sách Truyện Tranh</h3>
                    <div style="overflow-x: auto;">
                      <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.85rem;">
                        <thead>
                          <tr style="border-bottom: 2px solid rgba(255,255,255,0.08); color: var(--text-muted);">
                            <th style="padding: 12px 8px; font-weight: 700;">Ảnh bìa</th>
                            <th style="padding: 12px 8px; font-weight: 700;">Tên truyện</th>
                            <th style="padding: 12px 8px; font-weight: 700;">Loại</th>
                            <th style="padding: 12px 8px; font-weight: 700;">Trạng thái</th>
                            <th style="padding: 12px 8px; font-weight: 700; text-align: right;">Hành động</th>
                          </tr>
                        </thead>
                        <tbody id="admin-mangas-table-body"></tbody>
                      </table>
                    </div>
                  </div>

                  <!-- Add/Edit Manga -->
                  <div id="adm-content-manga" class="admin-tab-pane" style="display: none;">
                    <h3 id="manga-form-header-title" style="font-size: 1.25rem; font-weight: 800; color: white; margin-bottom: 20px;">Đăng Truyện Tranh Mới</h3>
                    <form id="admin-manga-form">
                      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px;">
                        <div class="form-group">
                          <label class="form-label">Tên truyện *</label>
                          <input type="text" id="manga-form-title" class="form-control" required />
                        </div>
                        <div class="form-group">
                          <label class="form-label">Tên thay thế</label>
                          <input type="text" id="manga-form-alt-title" class="form-control" />
                        </div>
                      </div>
                      <div class="form-group" style="margin-top: 15px;">
                        <label class="form-label">Tóm tắt *</label>
                        <textarea id="manga-form-description" class="form-control" style="min-height: 100px; resize: vertical;" required></textarea>
                      </div>
                      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-top: 15px;">
                        <div class="form-group">
                          <label class="form-label">Loại truyện *</label>
                          <select id="manga-form-type" class="form-control" required>
                            <option value="0">Manga (Nhật Bản)</option>
                            <option value="1">Manhwa (Hàn Quốc)</option>
                            <option value="2">Manhua (Trung Quốc)</option>
                          </select>
                        </div>
                        <div class="form-group">
                          <label class="form-label">Tình trạng *</label>
                          <select id="manga-form-status" class="form-control" required>
                            <option value="0">Đang tiến hành</option>
                            <option value="1">Đã hoàn thành</option>
                            <option value="2">Tạm ngưng</option>
                          </select>
                        </div>
                        <div class="form-group">
                          <label class="form-label">Năm phát hành</label>
                          <input type="number" id="manga-form-year" class="form-control" placeholder="2024" />
                        </div>
                      </div>
                      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-top: 15px;">
                        <div class="form-group">
                          <label class="form-label">Demographic</label>
                          <select id="manga-form-demographic" class="form-control">
                            <option value="0">Không có</option>
                            <option value="1">Shounen</option>
                            <option value="2">Shoujo</option>
                            <option value="3">Seinen</option>
                            <option value="4">Josei</option>
                          </select>
                        </div>
                        <div class="form-group">
                          <label class="form-label">Format</label>
                          <select id="manga-form-format" class="form-control">
                            <option value="0">Không có</option>
                            <option value="1">Adaptation</option>
                            <option value="2">WebComic</option>
                            <option value="3">OneShot</option>
                            <option value="4">Comic</option>
                            <option value="5">Book</option>
                          </select>
                        </div>
                      </div>
                      <div class="form-group" style="margin-top: 15px;">
                        <label class="form-label">Ảnh bìa (URL) *</label>
                        <input type="url" id="manga-form-cover" class="form-control" placeholder="https://..." required />
                      </div>
                      <div class="form-group" style="margin-top: 20px;">
                        <label class="form-label">Thể loại (Chọn nhiều) *</label>
                        <div id="manga-form-genres-checkbox-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; background-color: #0F1218; padding: 16px; border-radius: var(--radius-sm); border: 1px solid rgba(255,255,255,0.05); max-height: 200px; overflow-y: auto;"></div>
                      </div>
                      <div class="form-group" style="margin-top: 20px;">
                        <label class="form-label">Tác giả và Vai trò *</label>
                        <div style="display: flex; gap: 10px; margin-bottom: 12px;">
                          <select id="manga-form-author-select" class="form-control" style="flex: 2;">
                            <option value="">-- Chọn tác giả --</option>
                          </select>
                          <select id="manga-form-author-role" class="form-control" style="flex: 1;">
                            <option value="Story & Art">Story & Art</option>
                            <option value="Story">Story</option>
                            <option value="Art">Art</option>
                            <option value="Original Creator">Original Creator</option>
                          </select>
                          <button type="button" id="btn-add-form-author" class="btn btn-secondary" style="border-radius: 4px; padding: 0 16px;">Thêm</button>
                        </div>
                        <div id="manga-form-added-authors-list" style="display: flex; flex-direction: column; gap: 6px; background-color: #0F1218; padding: 12px; border-radius: var(--radius-sm); border: 1px solid rgba(255,255,255,0.05); min-height: 50px;">
                          <p style="color: var(--text-muted); font-size: 0.8rem; text-align: center; margin: 6px 0;">Chưa gán tác giả cho truyện.</p>
                        </div>
                      </div>
                      <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 30px;">
                        <button type="button" id="btn-cancel-manga-form" class="btn btn-secondary" style="display: none;">Huỷ chỉnh sửa</button>
                        <button type="submit" class="btn btn-primary" style="border-radius: 20px; font-weight: 700; padding: 10px 30px;">
                          <i data-lucide="check" style="width: 18px; height: 18px;"></i> Lưu Truyện
                        </button>
                      </div>
                    </form>
                  </div>

                  <!-- Add Chapter -->
                  <div id="adm-content-chapter" class="admin-tab-pane" style="display: none;">
                    <h3 style="font-size: 1.25rem; font-weight: 800; color: white; margin-bottom: 20px;">Thêm Chương Mới</h3>
                    <form id="admin-chapter-form">
                      <div class="form-group">
                        <label class="form-label">Truyện tranh *</label>
                        <select id="chapter-form-manga-select" class="form-control" required>
                          <option value="">-- Chọn truyện tranh --</option>
                        </select>
                      </div>
                      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-top: 15px;">
                        <div class="form-group">
                          <label class="form-label">Số thứ tự chương *</label>
                          <input type="number" step="any" id="chapter-form-number" class="form-control" required />
                        </div>
                        <div class="form-group">
                          <label class="form-label">Tên chương</label>
                          <input type="text" id="chapter-form-title" class="form-control" placeholder="Tuỳ chọn..." />
                        </div>
                      </div>
                      <div class="form-group" style="margin-top: 15px;">
                        <label class="form-label">Danh sách URL ảnh (mỗi link một dòng) *</label>
                        <textarea id="chapter-form-pages" class="form-control" style="min-height: 200px; resize: vertical;" placeholder="https://example.com/page1.jpg&#10;https://example.com/page2.jpg" required></textarea>
                      </div>
                      <div style="display: flex; justify-content: flex-end; margin-top: 30px;">
                        <button type="submit" class="btn btn-primary" style="border-radius: 20px; font-weight: 700; padding: 10px 30px;">
                          <i data-lucide="plus" style="width: 18px; height: 18px;"></i> Đăng Chương
                        </button>
                      </div>
                    </form>
                  </div>

                  <!-- Authors -->
                  <div id="adm-content-author" class="admin-tab-pane" style="display: none;">
                    <h3 style="font-size: 1.25rem; font-weight: 800; color: white; margin-bottom: 20px;">Tạo Tác Giả</h3>
                    <form id="admin-author-form">
                      <div class="form-group">
                        <label class="form-label">Tên tác giả *</label>
                        <input type="text" id="author-form-name" class="form-control" required />
                      </div>
                      <div class="form-group" style="margin-top: 15px;">
                        <label class="form-label">Tiểu sử</label>
                        <textarea id="author-form-biography" class="form-control" style="min-height: 100px; resize: vertical;"></textarea>
                      </div>
                      <div style="display: flex; justify-content: flex-end; margin-top: 30px;">
                        <button type="submit" class="btn btn-primary" style="border-radius: 20px; font-weight: 700; padding: 10px 30px;">
                          <i data-lucide="plus" style="width: 18px; height: 18px;"></i> Thêm Tác Giả
                        </button>
                      </div>
                    </form>
                  </div>

                  <!-- Genres -->
                  <div id="adm-content-genre" class="admin-tab-pane" style="display: none;">
                    <h3 style="font-size: 1.25rem; font-weight: 800; color: white; margin-bottom: 20px;">Tạo Thể Loại</h3>
                    <form id="admin-genre-form">
                      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
                        <div class="form-group">
                          <label class="form-label">Tên thể loại *</label>
                          <input type="text" id="genre-form-name" class="form-control" required />
                        </div>
                        <div class="form-group">
                          <label class="form-label">Slug *</label>
                          <input type="text" id="genre-form-slug" class="form-control" required />
                        </div>
                      </div>
                      <div style="display: flex; justify-content: flex-end; margin-top: 30px;">
                        <button type="submit" class="btn btn-primary" style="border-radius: 20px; font-weight: 700; padding: 10px 30px;">
                          <i data-lucide="plus" style="width: 18px; height: 18px;"></i> Thêm Thể Loại
                        </button>
                      </div>
                    </form>
                  </div>

                </div>
              </div>
            </div>
          </div>

        </div>
      </main>
    </div>

    <script src="/js/common.js?v=3.0"></script>
    <script src="/js/admin.js?v=3.0"></script>
    <style>
      .admin-tab-btn { background: transparent; color: var(--text-muted); border: none; cursor: pointer; }
      .admin-tab-btn:hover { background-color: rgba(255,255,255,0.04); color: white; }
      .admin-tab-btn.active { background-color: rgba(255,69,82,0.12) !important; color: #FF4552 !important; }
      th, td { padding: 10px 8px; border-bottom: 1px solid rgba(255,255,255,0.05); }
      tr:hover td { background-color: rgba(255,255,255,0.02); }
    </style>
  </body>
</html>
