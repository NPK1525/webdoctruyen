<div id="auth-modal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.75); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; z-index: 2000; padding: 20px;">
  <div class="glass-card" style="width: 100%; max-width: 420px; padding: 32px; border-radius: var(--radius-lg); position: relative; background-color: var(--bg-card); box-shadow: var(--shadow-lg);" onclick="event.stopPropagation()">
    <button id="auth-modal-close" style="position: absolute; top: 20px; right: 20px; color: var(--text-muted); cursor: pointer; background: none; border: none;" title="&#272;&#243;ng">
      <i data-lucide="x" style="width: 20px; height: 20px;"></i>
    </button>

    <div id="auth-modal-login-view">
      <h3 style="font-size: 1.5rem; font-weight: 800; color: var(--text-bright); margin-bottom: 24px;">&#272;&#259;ng nh&#7853;p</h3>
      <div id="login-error-message" style="display: none; background-color: rgba(255,69,82,0.15); border: 1px solid rgba(255,69,82,0.3); color: #FF4552; padding: 10px; border-radius: 6px; margin-bottom: 16px; font-size: 0.85rem; align-items: center; gap: 8px;">
        <i data-lucide="alert-circle" style="width: 16px; height: 16px; flex-shrink:0;"></i>
        <span class="msg-txt">T&#234;n &#273;&#259;ng nh&#7853;p/email ho&#7863;c m&#7853;t kh&#7849;u kh&#244;ng ch&#237;nh x&#225;c.</span>
      </div>
      <form id="login-form">
        <div class="form-group">
          <label class="form-label">T&#234;n &#273;&#259;ng nh&#7853;p ho&#7863;c email</label>
          <input type="text" id="login-username" class="form-control" placeholder="Nh&#7853;p t&#234;n &#273;&#259;ng nh&#7853;p ho&#7863;c email..." required autocomplete="username" />
        </div>
        <div class="form-group">
          <label class="form-label">M&#7853;t kh&#7849;u</label>
          <input type="password" id="login-password" class="form-control" placeholder="Nh&#7853;p m&#7853;t kh&#7849;u..." required autocomplete="current-password" />
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%; border-radius: 24px; margin-top: 16px; font-weight: 700;">&#272;&#259;ng nh&#7853;p</button>
      </form>
      <p style="text-align: center; font-size: 0.85rem; color: var(--text-muted); margin-top: 24px;">
        Ch&#432;a c&#243; t&#224;i kho&#7843;n? <span id="switch-to-register" style="color: var(--accent-primary); cursor: pointer; font-weight: 600;">&#272;&#259;ng k&#253; ngay</span>
      </p>
    </div>

    <div id="auth-modal-register-view" style="display: none;">
      <h3 style="font-size: 1.5rem; font-weight: 800; color: var(--text-bright); margin-bottom: 24px;">&#272;&#259;ng k&#253;</h3>
      <div id="register-error-message" style="display: none; background-color: rgba(255,69,82,0.15); border: 1px solid rgba(255,69,82,0.3); color: #FF4552; padding: 10px; border-radius: 6px; margin-bottom: 16px; font-size: 0.85rem; align-items: center; gap: 8px;">
        <i data-lucide="alert-circle" style="width: 16px; height: 16px; flex-shrink: 0;"></i>
        <span class="msg-txt">&#272;&#259;ng k&#253; kh&#244;ng th&#224;nh c&#244;ng.</span>
      </div>
      <form id="register-form">
        <div class="form-group">
          <label class="form-label">T&#234;n &#273;&#259;ng nh&#7853;p</label>
          <input type="text" id="register-username" class="form-control" placeholder="3-24 k&#253; t&#7921;, ch&#7919;/s&#7889;/_/-" minlength="3" maxlength="24" pattern="[A-Za-z0-9_-]{3,24}" required autocomplete="username" />
        </div>
        <div class="form-group">
          <label class="form-label">Email</label>
          <input type="email" id="register-email" class="form-control" placeholder="name@example.com" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label class="form-label">M&#7853;t kh&#7849;u</label>
          <input type="password" id="register-password" class="form-control" placeholder="&#205;t nh&#7845;t 8 k&#253; t&#7921;, g&#7891;m ch&#7919; v&#224; s&#7889;" minlength="8" maxlength="128" required autocomplete="new-password" />
        </div>
        <div class="form-group">
          <label class="form-label">X&#225;c nh&#7853;n m&#7853;t kh&#7849;u</label>
          <input type="password" id="register-confirm-password" class="form-control" placeholder="Nh&#7853;p l&#7841;i m&#7853;t kh&#7849;u..." minlength="8" maxlength="128" required autocomplete="new-password" />
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%; border-radius: 24px; margin-top: 16px; font-weight: 700;">&#272;&#259;ng k&#253;</button>
      </form>
      <p style="text-align: center; font-size: 0.85rem; color: var(--text-muted); margin-top: 24px;">
        &#272;&#227; c&#243; t&#224;i kho&#7843;n? <span id="switch-to-login" style="color: var(--accent-primary); cursor: pointer; font-weight: 600;">&#272;&#259;ng nh&#7853;p</span>
      </p>
    </div>
  </div>
</div>
