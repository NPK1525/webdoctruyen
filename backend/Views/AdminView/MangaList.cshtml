@model List<MangaNPK.Models.Manga>
@{
    ViewData["Title"] = "Quản lý Manga";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="section-title mb-0">Danh sách Manga</h1>
        <a asp-action="MangaCreate" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Thêm mới</a>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover">
                <thead>
                    <tr>
                        <th>Tên</th>
                        <th>Loại</th>
                        <th>Trạng thái</th>
                        <th>Thể loại</th>
                        <th>Chương</th>
                        <th>Ngày thêm</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>
                                <a asp-controller="MangaView" asp-action="Detail" asp-route-id="@m.Id" class="text-white text-decoration-none fw-semibold">@m.Title</a>
                            </td>
                            <td><span class="badge bg-danger">@m.Type</span></td>
                            <td>
                                @{
                                    var sc = m.Status switch { MangaStatus.Completed => "success", MangaStatus.Hiatus => "warning", _ => "primary" };
                                    var sl = m.Status switch { MangaStatus.Completed => "Hoàn thành", MangaStatus.Hiatus => "Tạm ngưng", _ => "Đang tiến hành" };
                                }
                                <span class="badge bg-@sc">@sl</span>
                            </td>
                            <td style="font-size:.8rem;">@string.Join(", ", m.MangaGenres.Select(g => g.Genre.Name).Take(3))</td>
                            <td>@m.Chapters.Count</td>
                            <td style="font-size:.8rem;">@m.CreatedAt.ToLocalTime().ToString("dd/MM/yy")</td>
                            <td>
                                <a asp-action="MangaEdit" asp-route-id="@m.Id" class="btn btn-sm btn-warning me-1"><i class="bi bi-pencil"></i></a>
                                <a asp-controller="AdminView" asp-action="ChapterCreate" asp-route-mangaId="@m.Id" class="btn btn-sm btn-success me-1"><i class="bi bi-plus"></i></a>
                                <form asp-action="MangaDelete" asp-route-id="@m.Id" method="post" style="display:inline;" onsubmit="return confirm('Xoá manga này?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-secondary">
            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
            <p>Chưa có manga nào. <a asp-action="MangaCreate">Thêm ngay</a></p>
        </div>
    }
</div>
