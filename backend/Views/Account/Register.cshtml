@{
    ViewData["Title"] = "\u0110\u0103ng k\u00fd";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card p-4">
                <h2 class="text-center fw-bold text-white mb-4"><i class="bi bi-person-plus-fill me-2 text-warning"></i>&#272;&#259;ng k&#253;</h2>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2">@ViewBag.Error</div>
                }

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">T&#234;n &#273;&#259;ng nh&#7853;p</label>
                        <input type="text" name="username" class="form-control" minlength="3" maxlength="24" pattern="[A-Za-z0-9_-]{3,24}" required autofocus autocomplete="username" />
                        <small class="text-secondary">3-24 k&#253; t&#7921;, ch&#7881; d&#249;ng ch&#7919;, s&#7889;, d&#7845;u g&#7841;ch d&#432;&#7899;i ho&#7863;c g&#7841;ch ngang.</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" required autocomplete="email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">M&#7853;t kh&#7849;u</label>
                        <input type="password" name="password" class="form-control" minlength="8" maxlength="128" required autocomplete="new-password" />
                        <small class="text-secondary">&#205;t nh&#7845;t 8 k&#253; t&#7921;, g&#7891;m ch&#7919; v&#224; s&#7889;.</small>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">X&#225;c nh&#7853;n m&#7853;t kh&#7849;u</label>
                        <input type="password" name="confirmPassword" class="form-control" minlength="8" maxlength="128" required autocomplete="new-password" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">T&#7841;o t&#224;i kho&#7843;n</button>
                </form>

                <hr style="border-color:#2a2a4a;" class="my-3" />
                <p class="text-center text-secondary mb-0">
                    &#272;&#227; c&#243; t&#224;i kho&#7843;n? <a asp-action="Login">&#272;&#259;ng nh&#7853;p</a>
                </p>
            </div>
        </div>
    </div>
</div>
