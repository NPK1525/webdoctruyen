@model MangaNPK.Models.Manga
@{
    ViewData["Title"] = "Chỉnh sửa: " + Model.Title;
    var authors = ViewBag.Authors as List<MangaNPK.Models.Author> ?? new();
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="MangaList" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
        <h1 class="section-title mb-0">Chỉnh sửa: @Model.Title</h1>
    </div>

    <form asp-action="MangaEdit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("_MangaForm", Model)
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-warning px-5"><i class="bi bi-check-circle me-2"></i>Lưu thay đổi</button>
            <a asp-controller="MangaView" asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Xem trang</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function addAuthorRow() {
            const authors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(authors.Select(a => new { a.Id, a.Name })));
            const container = document.getElementById('author-rows');
            const div = document.createElement('div');
            div.className = 'd-flex gap-2 mb-2 align-items-center';
            div.innerHTML = `
                <select name="authorIds" class="form-select" style="flex:2">
                    ${authors.map(a => `<option value="${a.id}">${a.name}</option>`).join('')}
                </select>
                <input type="text" name="authorRoles" class="form-control" placeholder="Story & Art" style="flex:1" value="Story & Art" />
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="this.parentElement.remove()"><i class="bi bi-x"></i></button>
            `;
            container.appendChild(div);
        }
    </script>
}
