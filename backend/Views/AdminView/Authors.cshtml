@model List<MangaNPK.Models.Author>
@{ Layout = null; }
<!DOCTYPE html><html lang="vi"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Quản lý tác giả - Admin</title><link rel="stylesheet" href="/css/style.css?v=4.9"><script src="https://unpkg.com/lucide@latest"></script></head><body class="admin-page reports-page"><div id="root"><header id="global-header" class="glass admin-global-header"><div class="container admin-header-inner"><div class="admin-brand-group"><button id="sidebar-toggle-btn" class="admin-menu-btn"><i data-lucide="menu"></i></button><a href="/admin" class="admin-brand"><i data-lucide="book-open"></i><span>Manga<span>NPK</span></span></a><span class="admin-panel-label">ADMIN CONTROL PANEL</span></div><div id="header-user-area" class="admin-user-area"></div></div></header>@await Html.PartialAsync("_Sidebar")<main class="reports-shell admin-reports-shell"><div class="reports-heading"><div><a class="reports-back" href="/admin">← Bảng quản trị</a><h1>Quản lý tác giả</h1><p>Thêm, chỉnh sửa và quản lý tác giả dùng trong form tạo truyện.</p></div><span class="reports-role-badge">AUTHORS</span></div><section class="management-grid"><form asp-action="AuthorCreate" method="post" class="reports-panel management-form">@Html.AntiForgeryToken()<h2>Thêm tác giả</h2><label>Tên tác giả<input name="name" required></label><label>Tiểu sử<textarea name="biography" rows="4"></textarea></label><button class="management-primary">Thêm tác giả</button></form><section class="reports-panel"><div class="management-toolbar"><input id="author-search" placeholder="Tìm tác giả..."></div><div class="management-list">@foreach (var a in Model) {<article class="management-row"><form asp-action="AuthorUpdate" asp-route-id="@a.Id" method="post">@Html.AntiForgeryToken()<input name="name" value="@a.Name" required><input name="biography" value="@a.Biography" type="hidden"><button class="management-save">Lưu</button></form><form asp-action="AuthorDelete" asp-route-id="@a.Id" method="post" onsubmit="return confirm('Xóa tác giả này?')">@Html.AntiForgeryToken()<button class="management-delete">Xóa</button></form></article>}@if (!Model.Any()) {<p class="management-empty">Chưa có tác giả nào.</p>}</div></section></section></main></div><script src="/js/common-auth.js?v=1.0"></script><script src="/js/common.js?v=5.6"></script><script>document.getElementById('author-search')?.addEventListener('input',e=>document.querySelectorAll('.management-row').forEach(r=>r.hidden=!r.textContent.toLowerCase().includes(e.target.value.toLowerCase())));</script></body></html>
