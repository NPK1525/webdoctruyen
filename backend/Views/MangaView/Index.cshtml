@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Advanced Search - MangaNPK</title>
    <link rel="stylesheet" href="/css/style.css?v=4.9" />
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body class="library-page advanced-search-page">
    <div id="root">
      @await Html.PartialAsync("_Header")
      @await Html.PartialAsync("_Sidebar")
      @await Html.PartialAsync("_AuthModal")

      <main id="main-layout">
        <div class="library-shell advanced-search-shell">
          <div class="library-page-title">
            <button type="button" onclick="history.back()" aria-label="Back">
              <i data-lucide="arrow-left"></i>
            </button>
            <h1>Advanced Search</h1>
          </div>

          <section class="advanced-search-panel">
            <div class="advanced-search-top">
              <label class="advanced-search-input">
                <i data-lucide="search"></i>
                <input id="advanced-search-input" type="search" placeholder="Search" autocomplete="off" />
              </label>
              <button id="advanced-toggle-filters" type="button" class="advanced-filter-toggle">
                <i data-lucide="chevron-down"></i>
                <span>Show filters</span>
              </button>
            </div>

            <div id="advanced-filters" class="advanced-filters" hidden>
              <label>
                <span>Sort by</span>
                <select id="advanced-sort">
                  <option value="">None</option>
                  <option value="latest">Latest upload</option>
                  <option value="title">Title</option>
                  <option value="year">Publication year</option>
                  <option value="views">Most viewed</option>
                </select>
              </label>
              <label>
                <span>Type</span>
                <select id="advanced-type">
                  <option value="">Any</option>
                  <option value="0">Manga</option>
                  <option value="1">Manhwa</option>
                  <option value="2">Manhua</option>
                </select>
              </label>
              <label>
                <span>Magazine Demographic</span>
                <select id="advanced-demographic">
                  <option value="">Any</option>
                  <option value="1">Shounen</option>
                  <option value="2">Shoujo</option>
                  <option value="3">Seinen</option>
                  <option value="4">Josei</option>
                </select>
              </label>
              <label>
                <span>Publication Status</span>
                <select id="advanced-status">
                  <option value="">Any</option>
                  <option value="0">Ongoing</option>
                  <option value="1">Completed</option>
                  <option value="2">Hiatus</option>
                </select>
              </label>
              <label>
                <span>Publication year</span>
                <input id="advanced-year" type="number" min="1900" max="2100" placeholder="Any" />
              </label>
              <label>
                <span>Content Rating</span>
                <select id="advanced-rating">
                  <option value="">Any</option>
                  <option value="safe">Safe</option>
                  <option value="suggestive">Suggestive</option>
                </select>
              </label>
            </div>

            <div class="advanced-actions">
              <button id="advanced-reset" type="button" class="advanced-reset-btn">Reset filters</button>
              <button id="advanced-lucky" type="button" class="advanced-lucky-btn">I'm feeling lucky</button>
              <button id="advanced-search-btn" type="button" class="advanced-search-btn">
                <i data-lucide="search"></i>
                <span>Search</span>
              </button>
            </div>
          </section>

          <div class="library-toolbar advanced-results-toolbar">
            <h2 id="advanced-count-label">0 Titles</h2>
            <div class="library-view-switcher">
              <button type="button" data-advanced-view="list" title="List view">
                <i data-lucide="list"></i>
              </button>
              <button type="button" data-advanced-view="compact" title="Compact view">
                <i data-lucide="rows-2"></i>
              </button>
              <button type="button" data-advanced-view="grid" title="Grid view">
                <i data-lucide="grid-2x2"></i>
              </button>
            </div>
          </div>

          <div id="advanced-loading" class="library-empty" style="display: none;">Loading...</div>
          <div id="advanced-empty" class="library-empty" style="display: none;"></div>
          <div id="advanced-results" class="library-items list"></div>
          <div id="advanced-pagination" class="library-pagination"></div>
        </div>
      </main>
    </div>

    <script src="/js/i18n.js?v=4.0"></script>
    <script src="/js/common-library.js?v=1.0"></script>
    <script src="/js/common-auth.js?v=1.0"></script>
<script src="/js/common.js?v=5.5"></script>
    <script src="/js/advanced-search.js?v=1.0"></script>
  </body>
</html>
