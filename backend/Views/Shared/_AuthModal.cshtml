<div id="auth-modal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.75); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; z-index: 2000; padding: 20px;">
  <div class="glass-card" style="width: 100%; max-width: 400px; padding: 32px; border-radius: var(--radius-lg); position: relative; background-color: #151A22; box-shadow: var(--shadow-lg);" onclick="event.stopPropagation()">
    <button id="auth-modal-close" style="position: absolute; top: 20px; right: 20px; color: var(--text-muted); cursor: pointer; background: none; border: none;" title="Đóng">
      <i data-lucide="x" style="width: 20px; height: 20px;"></i>
    </button>
    <div id="auth-modal-login-view">
      <h3 style="font-size: 1.5rem; font-weight: 800; color: white; margin-bottom: 24px;">Đăng Nhập</h3>
      <div id="login-error-message" style="display: none; background-color: rgba(255,69,82,0.15); border: 1px solid rgba(255,69,82,0.3); color: #FF4552; padding: 10px; border-radius: 6px; margin-bottom: 16px; font-size: 0.85rem; align-items: center; gap: 8px;">
        <i data-lucide="alert-circle" style="width: 16px; height: 16px; flex-shrink:0;"></i>
        <span class="msg-txt">Sai tài khoản hoặc mật khẩu.</span>
      </div>
      <form id="login-form">
        <div class="form-group">
          <label class="form-label">Tên đăng nhập</label>
          <input type="text" id="login-username" class="form-control" placeholder="Nhập tên đăng nhập..." required />
        </div>
        <div class="form-group">
          <label class="form-label">Mật khẩu</label>
          <input type="password" id="login-password" class="form-control" placeholder="Nhập mật khẩu..." required />
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%; border-radius: 24px; margin-top: 16px; font-weight: 700;">Đăng Nhập</button>
      </form>
      <p style="text-align: center; font-size: 0.85rem; color: var(--text-muted); margin-top: 24px;">
        Chưa có tài khoản? <span id="switch-to-register" style="color: #FF4552; cursor: pointer; font-weight: 600;">Đăng ký ngay</span>
      </p>
    </div>
    <div id="auth-modal-register-view" style="display: none;">
      <h3 style="font-size: 1.5rem; font-weight: 800; color: white; margin-bottom: 24px;">Đăng Ký</h3>
      <div id="register-error-message" style="display: none; background-color: rgba(255,69,82,0.15); border: 1px solid rgba(255,69,82,0.3); color: #FF4552; padding: 10px; border-radius: 6px; margin-bottom: 16px; font-size: 0.85rem; align-items: center; gap: 8px;">
        <i data-lucide="alert-circle" style="width: 16px; height: 16px; flex-shrink: 0;"></i>
        <span class="msg-txt">Đăng ký không thành công.</span>
      </div>
      <form id="register-form">
        <div class="form-group">
          <label class="form-label">Tên đăng nhập</label>
          <input type="text" id="register-username" class="form-control" placeholder="Tối thiểu 3 ký tự..." required />
        </div>
        <div class="form-group">
          <label class="form-label">Mật khẩu</label>
          <input type="password" id="register-password" class="form-control" placeholder="Tối thiểu 6 ký tự..." required />
        </div>
        <div class="form-group">
          <label class="form-label">Xác nhận mật khẩu</label>
          <input type="password" id="register-confirm-password" class="form-control" placeholder="Nhập lại mật khẩu..." required />
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%; border-radius: 24px; margin-top: 16px; font-weight: 700;">Đăng Ký</button>
      </form>
      <p style="text-align: center; font-size: 0.85rem; color: var(--text-muted); margin-top: 24px;">
        Đã có tài khoản? <span id="switch-to-login" style="color: #FF4552; cursor: pointer; font-weight: 600;">Đăng nhập</span>
      </p>
    </div>
  </div>
</div>
