@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reading History - MangaNPK</title>
    <link rel="stylesheet" href="/css/style.css?v=4.9" />
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body class="library-page history-page">
    <div id="root">
      @await Html.PartialAsync("_Header")
      @await Html.PartialAsync("_Sidebar")
      @await Html.PartialAsync("_AuthModal")

      <main id="main-layout" style="flex: 1; display: flex; flex-direction: column; width: 100%;">
        <div class="library-shell history-shell">
          <div class="library-title-row">
            <a href="/" class="library-back-btn" title="Back"><i data-lucide="arrow-left"></i></a>
            <h1 data-i18n="history.title">Reading History</h1>
          </div>

          <div id="history-content">
            <div class="library-toolbar history-toolbar">
              <h2 id="history-count-label">0 Titles</h2>
            </div>
            <div id="history-items" class="library-items list"></div>
            <div id="history-empty" class="library-empty" style="display: none;"></div>
          </div>
        </div>
      </main>
    </div>

    <script src="/js/i18n.js?v=4.0"></script>
    <script src="/js/common-library.js?v=1.0"></script>
    <script src="/js/common-auth.js?v=1.0"></script>
<script src="/js/common.js?v=5.5"></script>
    <script src="/js/history.js?v=4.6"></script>
  </body>
</html>
