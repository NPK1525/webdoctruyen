<header id="global-header" class="glass" style="position: sticky; top: 0; z-index: 1000; transition: all 0.3s ease;">
  <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 70px;">
    <div style="display: flex; align-items: center; gap: 15px;">
      <button id="sidebar-toggle-btn" style="color: var(--text-main); display: flex; align-items: center; cursor: pointer; background: none; border: none;" title="Menu">
        <i data-lucide="menu" style="width: 24px; height: 24px;"></i>
      </button>
      <div id="logo-btn" style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
        <div style="width: 38px; height: 38px; border-radius: 8px; background-color: #FF8C00; display: flex; align-items: center; justify-content: center;">
          <i data-lucide="book-open" style="width: 20px; height: 20px; color: white;"></i>
        </div>
        <span style="font-size: 1.35rem; font-weight: 800; letter-spacing: -0.02em; color: white;">
          Manga<span style="color: #FF8C00;">NPK</span>
        </span>
      </div>
    </div>
    <div style="display: flex; align-items: center; gap: 15px; flex: 1; justify-content: center; max-width: 700px; margin: 0 20px;">
      <div id="header-search-container" style="position: relative; width: 100%; max-width: 360px; display: flex; align-items: center;">
        <i data-lucide="search" style="width: 16px; height: 16px; color: var(--text-muted); position: absolute; left: 12px; pointer-events: none;"></i>
        <input id="header-search-input" type="text" placeholder="Tìm kiếm..." class="form-control"
          style="padding-left: 38px; padding-right: 64px; border-radius: 6px; height: 38px; background-color: #1E2026; border: 1px solid #2F333B; font-size: 0.85rem; width: 100%;" />
        <span style="position: absolute; right: 12px; font-size: 0.7rem; color: #6E7681; background-color: #2F333B; padding: 2px 6px; border-radius: 4px; pointer-events: none; font-weight: 600;">Ctrl K</span>
      </div>
    </div>
    <div id="header-user-area" style="display: flex; align-items: center; gap: 15px;"></div>
  </div>
</header>
