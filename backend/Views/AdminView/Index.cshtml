@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>B&#7843;ng Qu&#7843;n Tr&#7883; - MangaNPK</title>
    <link rel="stylesheet" href="/css/style.css?v=4.9" />
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body>
    <div id="root">
      <header id="global-header" class="glass" style="position: sticky; top: 0; z-index: 1000;">
        <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 70px;">
          <div style="display: flex; align-items: center; gap: 15px;">
            <button id="sidebar-toggle-btn" style="color: var(--text-main); display: flex; align-items: center; cursor: pointer; background: none; border: none;" title="Menu">
              <i data-lucide="menu" style="width: 24px; height: 24px;"></i>
            </button>
            <div id="logo-btn" style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
              <div style="width: 38px; height: 38px; border-radius: 8px; background-color: #FF8C00; display: flex; align-items: center; justify-content: center;">
                <i data-lucide="book-open" style="width: 20px; height: 20px; color: white;"></i>
              </div>
              <span style="font-size: 1.35rem; font-weight: 800; letter-spacing: -0.02em; color: white;">
                Manga<span style="color: #FF8C00;">NPK</span>
              </span>
            </div>
            <div style="width: 1px; height: 20px; background-color: rgba(255,255,255,0.1); margin: 0 10px;"></div>
            <span style="font-size: 0.95rem; font-weight: 700; color: #FF4552; text-transform: uppercase; letter-spacing: 0.05em;">Admin Control Panel</span>
          </div>
          <div id="header-user-area" style="display: flex; align-items: center; gap: 15px;"></div>
        </div>
      </header>

      @await Html.PartialAsync("_Sidebar")
      @await Html.PartialAsync("_AuthModal")

      <main id="main-layout" style="flex: 1; display: flex; flex-direction: column; width: 100%; margin-top: 24px; margin-bottom: 50px;">
        <div class="container">
          <div id="admin-access-denied" class="glass-card" style="padding: 40px; text-align: center; border-radius: var(--radius-lg); margin-top: 30px; display: none;">
            <i data-lucide="alert-circle" style="width: 48px; height: 48px; color: #FF4552; margin-bottom: 16px;"></i>
            <h2 style="font-size: 1.5rem; font-weight: 800; color: white; margin-bottom: 10px;">Truy c&#7853;p b&#7883; t&#7915; ch&#7889;i</h2>
            <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 24px;">B&#7841;n c&#7847;n &#273;&#259;ng nh&#7853;p b&#7857;ng t&#224;i kho&#7843;n Admin &#273;&#7875; truy c&#7853;p.</p>
            <a href="/" class="btn btn-primary" style="border-radius: 20px;">V&#7873; trang ch&#7911;</a>
          </div>

          <div id="admin-panel-wrapper" style="display: none;">
            <div style="display: flex; gap: 30px; flex-wrap: wrap;">
              <div style="width: 250px; flex-shrink: 0; display: flex; flex-direction: column; gap: 6px;">
                <h4 style="font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; padding: 10px 16px; margin: 0;">Qu&#7843;n l&#253;</h4>
                <button class="admin-tab-btn active" data-tab="manga-list" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="book-open" style="width: 18px; height: 18px;"></i><span>Danh s&#225;ch truy&#7879;n</span>
                </button>
                <button class="admin-tab-btn" data-tab="title-draft" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="file-plus-2" style="width: 18px; height: 18px;"></i><span>Đăng truyện</span>
                </button>
                <button class="admin-tab-btn" data-tab="manga" style="display: none; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="plus" style="width: 18px; height: 18px;"></i><span id="tab-label-manga-form">&#272;&#259;ng truy&#7879;n m&#7899;i</span>
                </button>
                <button class="admin-tab-btn" data-tab="chapter" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="layers" style="width: 18px; height: 18px;"></i><span>Th&#234;m ch&#432;&#417;ng m&#7899;i</span>
                </button>
                <button class="admin-tab-btn" data-tab="mangadex" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="download-cloud" style="width: 18px; height: 18px;"></i><span>Nh&#7853;p MangaDex</span>
                </button>
                <button class="admin-tab-btn" data-tab="author" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="users" style="width: 18px; height: 18px;"></i><span>Qu&#7843;n l&#253; t&#225;c gi&#7843;</span>
                </button>
                <button class="admin-tab-btn" data-tab="genre" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-align: left; width: 100%; transition: all 0.2s;">
                  <i data-lucide="tag" style="width: 18px; height: 18px;"></i><span>Qu&#7843;n l&#253; th&#7875; lo&#7841;i</span>
                </button>
              </div>

              <div style="flex: 1; min-width: 320px;">
                <div class="glass-card" style="padding: 30px; border-radius: var(--radius-lg);">
                  <div id="admin-toast-message" style="display: none; padding: 12px 16px; border-radius: 6px; margin-bottom: 24px; font-size: 0.85rem; align-items: center; gap: 8px;">
                    <i data-lucide="check" class="icon-success" style="width: 16px; height: 16px; display: none;"></i>
                    <i data-lucide="alert-circle" class="icon-error" style="width: 16px; height: 16px; display: none;"></i>
                    <span class="msg-text"></span>
                  </div>

                  <div id="adm-content-manga-list" class="admin-tab-pane">
                    <h3 style="font-size: 1.25rem; font-weight: 800; color: white; margin-bottom: 20px;">Danh s&#225;ch truy&#7879;n tranh</h3>
                    <div class="admin-manga-filters" id="admin-manga-filters">
                      <div class="admin-manga-search-row">
                        <div class="admin-manga-search-wrap"><i data-lucide="search"></i><input id="admin-manga-search" class="form-control" type="search" placeholder="Tìm theo tên truyện hoặc tác giả..." /></div>
                        <button type="button" id="admin-manga-reset" class="btn btn-secondary">Đặt lại</button>
                      </div>
                      <div class="admin-manga-filter-grid">
                        <select id="admin-manga-type" class="form-control"><option value="">Tất cả loại</option><option value="0">Manga</option><option value="1">Manhwa</option><option value="2">Manhua</option><option value="3">Webtoon</option><option value="4">Comic</option></select>
                        <select id="admin-manga-status" class="form-control"><option value="">Tất cả trạng thái</option><option value="0">Ongoing</option><option value="1">Completed</option><option value="2">Hiatus</option><option value="3">Cancelled</option></select>
                        <select id="admin-manga-source" class="form-control"><option value="">Tất cả nguồn</option><option value="Local">Local</option><option value="MangaDex">MangaDex</option></select>
                        <select id="admin-manga-chapter-state" class="form-control"><option value="">Tất cả chapter</option><option value="with-chapters">Đã có chapter</option><option value="without-chapters">Chưa có chapter</option></select>
                        <select id="admin-manga-sort" class="form-control"><option value="newest">Mới nhất</option><option value="oldest">Cũ nhất</option><option value="title-asc">Tên A-Z</option><option value="chapter-count">Nhiều chapter nhất</option></select>
                        <select id="admin-manga-page-size" class="form-control"><option value="20" selected>20 truyện/trang</option><option value="50">50 truyện/trang</option><option value="100">100 truyện/trang</option></select>
                      </div>
                      <div id="admin-manga-count-label" class="admin-manga-count-label"></div>
                    </div>
                    <div style="overflow-x: auto;">
                      <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.85rem;">
                        <thead>
                          <tr style="border-bottom: 2px solid rgba(255,255,255,0.08); color: var(--text-muted);">
                            <th style="padding: 12px 8px; font-weight: 700;">&#7842;nh b&#236;a</th>
                            <th style="padding: 12px 8px; font-weight: 700;">T&#234;n truy&#7879;n</th>
                            <th style="padding: 12px 8px; font-weight: 700;">Lo&#7841;i</th>
                            <th style="padding: 12px 8px; font-weight: 700;">Tr&#7841;ng th&#225;i</th>
                            <th style="padding: 12px 8px; font-weight: 700; text-align: right;">H&#224;nh &#273;&#7897;ng</th>
                          </tr>
                        </thead>
                        <tbody id="admin-mangas-table-body"></tbody>
                      </table>
                    </div>
                    <div id="admin-manga-pagination" class="admin-manga-pagination"></div>
                  </div>

                  <div id="adm-content-title-draft" class="admin-tab-pane" style="display: none;">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:20px;flex-wrap:wrap;">
                      <div>
                        <h3 style="font-size:1.25rem;font-weight:800;color:white;margin:0 0 6px;">Đăng truyện mới</h3>
                        <p style="color:var(--text-muted);font-size:0.88rem;margin:0;">Điền thông tin truyện và đăng trực tiếp lên hệ thống.</p>
                      </div>
                      <button type="button" id="btn-new-title-draft" class="btn btn-primary" style="border-radius:20px;font-weight:700;padding:10px 20px;">
                        <i data-lucide="file-plus-2" style="width:18px;height:18px;"></i> B&#7843;n nh&#225;p m&#7899;i
                      </button>
                    </div>

                    <div id="title-draft-list-panel" style="margin-bottom:22px;border:1px solid rgba(255,255,255,0.08);border-radius:8px;overflow:hidden;background:rgba(255,255,255,0.02);">
                      <table style="width:100%;border-collapse:collapse;text-align:left;font-size:0.85rem;">
                        <thead>
                          <tr style="border-bottom:1px solid rgba(255,255,255,0.08);color:var(--text-muted);">
                            <th style="padding:10px;">&#7842;nh</th>
                            <th style="padding:10px;">T&#234;n truy&#7879;n</th>
                            <th style="padding:10px;">Tr&#7841;ng th&#225;i duy&#7879;t</th>
                            <th style="padding:10px;">C&#7853;p nh&#7853;t</th>
                            <th style="padding:10px;text-align:right;">H&#224;nh &#273;&#7897;ng</th>
                          </tr>
                        </thead>
                        <tbody id="title-drafts-table-body"></tbody>
                      </table>
                    </div>

                    <form id="title-draft-form" style="display:none;">
                      <input type="hidden" id="title-draft-id" />
                      <div class="title-draft-shell">
                        <aside class="title-draft-nav">
                          <button type="button" class="title-draft-section-btn active" data-section="basic"><i data-lucide="book-open"></i><span>Ti&#234;u &#273;&#7873;</span></button>
                          <button type="button" class="title-draft-section-btn" data-section="publish"><i data-lucide="list"></i><span>Xu&#7845;t b&#7843;n</span></button>
                          <button type="button" class="title-draft-section-btn" data-section="authors"><i data-lucide="users"></i><span>T&#225;c gi&#7843;</span></button>
                          <button type="button" class="title-draft-section-btn" data-section="tags"><i data-lucide="tag"></i><span>Ph&#226;n lo&#7841;i</span></button>
                          <button type="button" class="title-draft-section-btn" data-section="images"><i data-lucide="image"></i><span>H&#236;nh &#7843;nh</span></button>
                          <button type="button" class="title-draft-section-btn" data-section="links"><i data-lucide="globe"></i><span>Li&#234;n k&#7871;t</span></button>
                          <button type="button" class="title-draft-section-btn" data-section="translation"><i data-lucide="languages"></i><span>D&#7883;ch thu&#7853;t</span></button>
                          <button type="button" class="title-draft-section-btn" data-section="review"><i data-lucide="shield-check"></i><span>Qu&#7843;n tr&#7883;</span></button>
                        </aside>

                        <section class="title-draft-main">
                          <div class="title-draft-section active" data-section-panel="basic">
                            <h4>Th&#244;ng tin c&#417; b&#7843;n</h4>
                            <div class="draft-grid two">
                              <label class="form-group"><span class="form-label">T&#234;n truy&#7879;n *</span><input id="draft-title" class="form-control" required /></label>
                              <label class="form-group"><span class="form-label">T&#234;n g&#7889;c</span><input id="draft-original-title" class="form-control" /></label>
                              <label class="form-group"><span class="form-label">T&#234;n ti&#7871;ng Anh</span><input id="draft-english-title" class="form-control" /></label>
                              <label class="form-group"><span class="form-label">T&#234;n kh&#225;c</span><input id="draft-alternative-titles" class="form-control" placeholder="C&#225;ch nhau b&#7857;ng d&#7845;u |" /></label>
                            </div>
                            <label class="form-group" style="margin-top:14px;"><span class="form-label">M&#244; t&#7843; / Synopsis *</span><textarea id="draft-description" class="form-control" style="min-height:140px;resize:vertical;" required></textarea></label>
                          </div>

                          <div class="title-draft-section" data-section-panel="publish">
                            <h4>Th&#244;ng tin xu&#7845;t b&#7843;n</h4>
                            <div class="draft-grid three">
                              <label class="form-group"><span class="form-label">Ng&#244;n ng&#7919; g&#7889;c</span><select id="draft-original-language" class="form-control"><option value="vi">Ti&#7871;ng Vi&#7879;t</option><option value="ja">Ti&#7871;ng Nh&#7853;t</option><option value="ko">Ti&#7871;ng H&#224;n</option><option value="zh">Ti&#7871;ng Trung</option><option value="en">Ti&#7871;ng Anh</option></select></label>
                              <label class="form-group"><span class="form-label">Lo&#7841;i truy&#7879;n</span><select id="draft-type" class="form-control"><option value="0">Manga</option><option value="1">Manhwa</option><option value="2">Manhua</option><option value="3">Webtoon</option><option value="4">Comic</option></select></label>
                              <label class="form-group"><span class="form-label">T&#236;nh tr&#7841;ng</span><select id="draft-status" class="form-control"><option value="0">&#272;ang ph&#225;t h&#224;nh</option><option value="1">Ho&#224;n th&#224;nh</option><option value="2">T&#7841;m ng&#432;ng</option><option value="3">&#272;&#227; h&#7911;y</option></select></label>
                              <label class="form-group"><span class="form-label">N&#259;m ph&#225;t h&#224;nh</span><input id="draft-release-year" type="number" min="1900" max="2100" class="form-control" /></label>
                            </div>
                          </div>

                          <div class="title-draft-section" data-section-panel="authors">
                            <h4>T&#225;c gi&#7843;</h4>
                            <div style="display:grid;grid-template-columns:2fr 1fr auto;gap:10px;align-items:end;">
                              <label class="form-group"><span class="form-label">Tác giả có sẵn</span><select id="draft-author-select" class="form-control"><option value="">-- Chọn tác giả --</option></select></label>
                              <label class="form-group"><span class="form-label">Vai trò</span><select id="draft-author-role" class="form-control"><option value="Story &amp; Art">Story &amp; Art</option><option value="Story">Story</option><option value="Art">Art</option></select></label>
                              <button type="button" id="btn-add-draft-author" class="btn btn-secondary">Thêm</button>
                            </div>
                            <div style="display:grid;grid-template-columns:2fr 1fr auto;gap:10px;align-items:end;margin-top:10px;">
                              <label class="form-group"><span class="form-label">Hoặc nhập tác giả mới</span><input id="draft-new-author-name" class="form-control" /></label>
                              <span></span><span></span>
                            </div>
                            <div id="draft-authors-list" class="taxonomy-chip-list" style="margin-bottom:14px;"></div>
                            <label class="form-group"><span class="form-label">Nhà xuất bản</span><input id="draft-publisher" class="form-control" /></label>
                          </div>

                          <div class="title-draft-section" data-section-panel="tags">
                            <h4>Ph&#226;n lo&#7841;i</h4>
                            <div class="draft-grid two">
                              <label class="form-group"><span class="form-label">&#272;&#7889;i t&#432;&#7907;ng</span><select id="draft-demographic" class="form-control"><option value="0">Kh&#244;ng x&#225;c &#273;&#7883;nh</option><option value="1">Shounen</option><option value="2">Shoujo</option><option value="3">Seinen</option><option value="4">Josei</option></select></label>
                              <label class="form-group"><span class="form-label">&#272;&#7897; tu&#7893;i</span><select id="draft-age-rating" class="form-control"><option value="0">M&#7885;i l&#7913;a tu&#7893;i</option><option value="1">13+</option><option value="2">16+</option><option value="3">18+</option></select></label>
                            </div>
                            <label class="form-group" style="margin-top:14px;"><span class="form-label">Format chính</span><select id="draft-format" class="form-control"><option value="0">Không có</option><option value="1">Adaptation</option><option value="2">WebComic</option><option value="3">OneShot</option><option value="4">Comic</option><option value="5">Book</option></select></label>
                            <div class="form-group" style="margin-top:14px;"><span class="form-label">Thể loại</span><div id="draft-genres-checkbox-container" class="draft-check-grid"></div></div>
                            <div class="form-group" style="margin-top:14px;"><span class="form-label">Ch&#7911; &#273;&#7873; / Theme</span><div id="draft-themes-checkbox-container" class="draft-check-grid"></div></div>
                            <div class="form-group" style="margin-top:14px;"><span class="form-label">Content Warning</span><div class="taxonomy-chip-list"><label class="taxonomy-chip warning-chip"><input type="checkbox" name="draft-content-warning" value="Gore" /><span>Gore</span></label><label class="taxonomy-chip warning-chip"><input type="checkbox" name="draft-content-warning" value="Sexual Violence" /><span>Sexual Violence</span></label></div></div>
                          </div>

                          <div class="title-draft-section" data-section-panel="images">
                            <h4>H&#236;nh &#7843;nh</h4>
                            <div class="draft-grid two">
                              <label class="form-group"><span class="form-label">&#7842;nh b&#236;a *</span><input id="draft-cover-url" class="form-control" placeholder="/uploads/cover.webp" /></label>
                              <label class="form-group"><span class="form-label">Banner</span><input id="draft-banner-url" class="form-control" placeholder="/uploads/banner.webp" /></label>
                            </div>
                            <div style="display:flex;gap:12px;margin-top:12px;flex-wrap:wrap;">
                              <input id="draft-cover-file-input" type="file" accept="image/*" style="display:none;" />
                              <button type="button" id="btn-upload-draft-cover" class="btn btn-secondary" style="border-radius:18px;">T&#7843;i &#7843;nh b&#236;a</button>
                              <input id="draft-banner-file-input" type="file" accept="image/*" style="display:none;" />
                              <button type="button" id="btn-upload-draft-banner" class="btn btn-secondary" style="border-radius:18px;">T&#7843;i banner</button>
                            </div>
                            <div id="draft-image-preview" style="display:flex;gap:16px;margin-top:16px;flex-wrap:wrap;"></div>
                          </div>

                          <div class="title-draft-section" data-section-panel="links">
                            <h4>Li&#234;n k&#7871;t</h4>
                            <div class="draft-grid three">
                              <label class="form-group"><span class="form-label">Website ch&#237;nh th&#7913;c</span><input id="draft-official-website" class="form-control" /></label>
                              <label class="form-group"><span class="form-label">Ngu&#7891;n tham kh&#7843;o</span><input id="draft-reference-url" class="form-control" /></label>
                              <label class="form-group"><span class="form-label">Trang theo d&#245;i</span><input id="draft-tracking-url" class="form-control" placeholder="AniList / MAL..." /></label>
                            </div>
                            <div class="draft-grid two" style="margin-top:14px;">
                              <label class="form-group"><span class="form-label">Ngu&#7891;n d&#7919; li&#7879;u</span><select id="draft-data-source" class="form-control"><option value="Local">N&#7897;i b&#7897;</option><option value="MangaDex">MangaDex</option></select></label>
                              <label class="form-group"><span class="form-label">MangaDex ID</span><input id="draft-mangadex-id" class="form-control" disabled /></label>
                            </div>
                          </div>

                          <div class="title-draft-section" data-section-panel="translation">
                            <h4>Th&#244;ng tin d&#7883;ch</h4>
                            <div class="draft-grid two">
                              <label class="form-group"><span class="form-label">Nh&#243;m d&#7883;ch</span><input id="draft-scanlation-group" class="form-control" /></label>
                              <label class="form-group"><span class="form-label">Ng&#244;n ng&#7919; b&#7843;n d&#7883;ch</span><input class="form-control" value="Ti&#7871;ng Vi&#7879;t" disabled /></label>
                            </div>
                            <label class="form-group" style="margin-top:14px;"><span class="form-label">Ghi ch&#250;</span><textarea id="draft-note" class="form-control" style="min-height:100px;resize:vertical;"></textarea></label>
                          </div>

                          <div class="title-draft-section" data-section-panel="review">
                            <h4>Qu&#7843;n tr&#7883;</h4>
                            <div class="draft-grid three">
                              <label class="form-group"><span class="form-label">Tr&#7841;ng th&#225;i duy&#7879;t</span><input id="draft-review-status-label" class="form-control" value="Nh&#225;p" disabled /></label>
                              <label class="form-group"><span class="form-label">Ng&#432;&#7901;i t&#7841;o</span><input id="draft-created-by-label" class="form-control" disabled /></label>
                              <label class="form-group"><span class="form-label">Ng&#224;y t&#7841;o</span><input id="draft-created-at-label" class="form-control" disabled /></label>
                            </div>
                            <label class="form-group" style="margin-top:14px;"><span class="form-label">L&#253; do t&#7915; ch&#7889;i</span><textarea id="draft-rejection-reason" class="form-control" style="min-height:80px;resize:vertical;" placeholder="Nh&#7853;p l&#253; do khi t&#7915; ch&#7889;i..."></textarea></label>
                          </div>

                          <div class="title-draft-actions">
