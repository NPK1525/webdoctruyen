@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Library - MangaNPK</title>
    <link rel="stylesheet" href="/css/style.css?v=4.9" />
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body class="library-page">
    <div id="root">
      @await Html.PartialAsync("_Header")
      @await Html.PartialAsync("_Sidebar")
      @await Html.PartialAsync("_AuthModal")

      <main id="main-layout" style="flex: 1; display: flex; flex-direction: column; width: 100%;">
        <div class="library-shell">
          <div class="library-title-row">
            <a href="/" class="library-back-btn" title="Back"><i data-lucide="arrow-left"></i></a>
            <h1 data-i18n="library.title">Library</h1>
          </div>

          <div id="library-login-prompt" class="library-login-prompt" style="display: none;">
            <p data-i18n="library.loginRequired">Please log in to view your library.</p>
            <button id="library-login-btn" class="btn btn-primary" data-i18n="auth.login">Log In</button>
          </div>

          <div id="library-content" style="display: none;">
            <div class="library-status-tabs" id="library-status-tabs"></div>
            <div class="library-toolbar">
              <h2 id="library-count-label">0 Titles</h2>
              <div class="library-view-switcher">
                <button data-library-view="list" title="List"><i data-lucide="list"></i></button>
                <button data-library-view="compact" title="Compact"><i data-lucide="rows-2"></i></button>
                <button data-library-view="grid" title="Grid"><i data-lucide="grid-2x2"></i></button>
              </div>
            </div>
            <div id="library-items" class="library-items"></div>
            <div id="library-empty" class="library-empty" style="display: none;"></div>
            <div id="library-pagination" class="library-pagination"></div>
          </div>
        </div>
      </main>
    </div>

    <script src="/js/i18n.js?v=4.0"></script>
    <script src="/js/common-library.js?v=1.0"></script>
    <script src="/js/common-auth.js?v=1.0"></script>
<script src="/js/common.js?v=5.5"></script>
    <script src="/js/library.js?v=4.6"></script>
  </body>
</html>
