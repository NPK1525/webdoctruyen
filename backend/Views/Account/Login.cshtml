@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card p-4">
                <h2 class="text-center fw-bold text-white mb-4"><i class="bi bi-person-fill me-2 text-danger"></i>Đăng nhập</h2>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2">@ViewBag.Error</div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    @if (ViewBag.ReturnUrl != null)
                    {
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    }
                    <div class="mb-3">
                        <label class="form-label">Tên đăng nhập</label>
                        <input type="text" name="username" class="form-control" required autofocus />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Mật khẩu</label>
                        <input type="password" name="password" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
                </form>

                <hr style="border-color:#2a2a4a;" class="my-3" />
                <p class="text-center text-secondary mb-0">
                    Chưa có tài khoản? <a asp-action="Register">Đăng ký ngay</a>
                </p>
            </div>
        </div>
    </div>
</div>
