@model List<MangaNPK.Models.Genre>
@{
    ViewData["Title"] = "Quản lý Thể loại";
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
        <h1 class="section-title mb-0">Quản lý Thể loại</h1>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card p-3">
                <h5 class="text-white mb-3">Thêm thể loại mới</h5>
                <form asp-action="GenreCreate" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Tên thể loại <span class="text-danger">*</span></label>
                        <input type="text" name="name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Slug <span class="text-secondary">(tuỳ chọn)</span></label>
                        <input type="text" name="slug" class="form-control" placeholder="tu-dong-tao" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Thêm</button>
                </form>
            </div>
        </div>
        <div class="col-md-8">
            <input id="genre-search" type="search" class="form-control mb-3" placeholder="Tìm thể loại..." />
            <table class="table table-dark table-hover">
                <thead><tr><th>#</th><th>Tên</th><th>Slug</th><th></th></tr></thead>
                <tbody>
                    @foreach (var g in Model)
                    {
                        <tr>
                            <td>@g.Id</td>
                            <td>@g.Name</td>
                            <td><code class="text-secondary">@g.Slug</code></td>
                            <td>
                                <form asp-action="GenreDelete" asp-route-id="@g.Id" method="post" style="display:inline;" onsubmit="return confirm('Xoá thể loại này?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="4" class="text-center text-secondary">Chưa có thể loại nào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
(() => {
  const input = document.getElementById('genre-search');
  if (!input) return;
  const rows = [...document.querySelectorAll('table tbody tr')].filter(row => !row.querySelector('td[colspan]'));
  input.addEventListener('input', () => {
    const term = input.value.trim().toLocaleLowerCase();
    rows.forEach(row => { row.style.display = row.textContent.toLocaleLowerCase().includes(term) ? '' : 'none'; });
  });
})();
</script>
