@model MangaNPK.Models.Chapter
@{
    Layout = null;
    var allChapters = ViewBag.AllChapters as List<MangaNPK.Models.Chapter> ?? new();
    var chapterJson = System.Text.Json.JsonSerializer.Serialize(new {
        id = Model.Id,
        mangaId = Model.MangaId,
        mangaTitle = Model.Manga?.Title ?? "",
        chapterNumber = Model.ChapterNumber,
        title = Model.Title,
        uploadedAt = Model.UploadedAt,
        authors = Model.Manga?.MangaAuthors?.Select(a => new { name = a.Author.Name, role = a.Role }),
        pages = Model.Pages.Select(p => new { id = p.Id, pageNumber = p.PageNumber, imageUrl = p.ImageUrl }),
        prevChapterId = ViewBag.PrevChapterId,
        nextChapterId = ViewBag.NextChapterId
    });
    var mangaChaptersJson = System.Text.Json.JsonSerializer.Serialize(new {
        id = Model.MangaId,
        title = Model.Manga?.Title ?? "",
        description = Model.Manga?.Description ?? "",
        coverUrl = Model.Manga?.CoverUrl ?? "",
        type = Model.Manga?.Type.ToString() ?? "Manga",
        status = Model.Manga?.Status.ToString() ?? "Ongoing",
        viewCount = Model.Manga?.ViewCount ?? 0,
        authors = Model.Manga?.MangaAuthors?.Select(a => new { name = a.Author.Name, role = a.Role }),
        chapters = allChapters.Select(c => new { id = c.Id, chapterNumber = c.ChapterNumber, title = c.Title })
    });
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Manga?.Title - Ch&#432;&#417;ng @Model.ChapterNumber - MangaNPK</title>
    <link rel="stylesheet" href="/css/style.css?v=4.9" />
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body style="background-color: #090B0F;" class="reader-page">
    <div id="root">
      <header id="global-header" class="glass" style="position: absolute; top: 0; left: 0; right: 0; z-index: 1000; transition: transform 0.3s ease; width: 100%;">
        <div style="display: flex; align-items: center; justify-content: space-between; height: 60px; padding: 0 20px;">
          <div style="display: flex; align-items: center; gap: 15px;">
            <button id="sidebar-toggle-btn" style="color: var(--text-main); display: flex; align-items: center; cursor: pointer; background: none; border: none;" title="Menu">
              <i data-lucide="menu" style="width: 22px; height: 22px;"></i>
            </button>
            <div id="logo-btn" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
              <div style="width: 32px; height: 32px; border-radius: 6px; background-color: #FF8C00; display: flex; align-items: center; justify-content: center;">
                <i data-lucide="book-open" style="width: 16px; height: 16px; color: white;"></i>
              </div>
              <span style="font-size: 1.15rem; font-weight: 800; letter-spacing: -0.02em; color: white; display: inline-block;">Manga<span style="color: #FF8C00;">NPK</span></span>
            </div>
            <div style="width: 1px; height: 20px; background-color: rgba(255,255,255,0.1); margin: 0 5px;" class="desktop-only"></div>
            <div id="reader-manga-title-breadcrumb" style="font-size: 0.9rem; font-weight: 700; color: #FF8C00; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; cursor: pointer;" class="desktop-only">@Model.Manga?.Title</div>
          </div>
          <div class="reader-header-search" id="reader-header-search-container">
            <i data-lucide="search" style="width: 16px; height: 16px;"></i>
              <input id="reader-header-search-input" type="search" placeholder="T&#236;m ki&#7871;m..." autocomplete="off" />
            <span>Ctrl</span><span>K</span>
          </div>
          <div style="display: flex; align-items: center; gap: 12px;">
            <div id="header-user-area" style="display: flex; align-items: center;"></div>
          </div>
        </div>
      </header>

      @await Html.PartialAsync("_Sidebar")
      @await Html.PartialAsync("_AuthModal")

      <main id="main-layout" style="flex: 1; display: flex; flex-direction: column; width: 100%; padding-top: 60px;">
        <div id="reader-loading-spinner" style="display: none;"></div>
        <div id="reader-main-content" style="display: block; width: 100%; position: relative; flex: 1;">
          <div class="reader-info-panel">
            <div class="reader-title-block">
            <div id="reader-chapter-title-p" class="reader-chapter-kicker">Ch&#432;&#417;ng @Model.ChapterNumber@(string.IsNullOrEmpty(Model.Title) || Model.Title == $"Ch\u01B0\u01A1ng {Model.ChapterNumber}" ? "" : ": " + Model.Title)</div>
              <h2 id="reader-manga-title-h2">@Model.Manga?.Title</h2>
              <div id="reader-author-name" class="reader-author-line">
                <i data-lucide="users" style="width: 18px; height: 18px;"></i>
              <span>&#272;ang c&#7853;p nh&#7853;t</span>
              </div>
            </div>
            <div class="reader-control-grid">
              <div style="position: relative;" id="chapter-select-dropdown-container">
                <div id="chapter-select-trigger" class="reader-select-trigger">
                  <span id="current-chapter-label">Ch&#432;&#417;ng @Model.ChapterNumber</span>
                </div>
              </div>
              <div style="position: relative;" id="page-select-dropdown-container">
                <div id="page-select-trigger" class="reader-select-trigger">
                  <span id="current-page-label">Trang -- / --</span>
                </div>
              </div>
              <div style="position: relative;" id="reader-settings-dropdown-container">
                <button id="reader-settings-btn" class="reader-select-trigger reader-menu-trigger" title="Menu">
                  <span>Menu</span>
                  <i data-lucide="chevron-left" style="width: 16px; height: 16px;"></i>
                </button>
              </div>
            </div>
          </div>
          <div style="height: 1px; background-color: rgba(255,255,255,0.08); width: 100%;" id="reader-divider-line"></div>
          <div id="reader-viewer-pane" style="position: relative; width: 100%; display: flex; flex-direction: column; align-items: center; margin: 0 auto; user-select: none;">
            <div id="reader-navigation-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 10; display: flex; pointer-events: none;">
              <div id="nav-zone-left" style="width: 50%; height: 100%; pointer-events: auto;"></div>
              <div id="nav-zone-right" style="width: 50%; height: 100%; pointer-events: auto;"></div>
            </div>
            <div id="viewer-scroll-container" style="display: flex; flex-direction: column; width: 100%; gap: 12px; align-items: center; padding: 20px 0;"></div>
            <div id="viewer-slide-container" style="display: none; width: 100%; justify-content: center; align-items: center; min-height: 70vh; padding: 20px 0;"></div>
          </div>
          <div class="reader-bottom-bar">
            <button id="btn-bottom-prev" class="btn btn-secondary" style="border-radius: 20px; padding: 8px 24px; font-weight: 700;">
              <i data-lucide="chevron-left" style="width: 16px; height: 16px;"></i> Ch&#432;&#417;ng Tr&#432;&#7899;c
            </button>
            <button id="btn-bottom-next" class="btn btn-primary" style="border-radius: 20px; padding: 8px 24px; font-weight: 700;">
              Ch&#432;&#417;ng Ti&#7871;p Theo <i data-lucide="chevron-right" style="width: 16px; height: 16px;"></i>
            </button>
          </div>
        </div>
      </main>
      <div class="reader-progress-track" aria-hidden="true">
        <div id="reader-reading-progress" class="reader-progress-fill"></div>
        <span id="reader-progress-label" class="reader-progress-label">0 / 0</span>
      </div>
      <div id="reader-drawer-overlay" class="reader-drawer-overlay"></div>
      <aside id="reader-menu-drawer" class="reader-menu-drawer" aria-hidden="true">
        <div class="reader-drawer-header">
          <button id="reader-drawer-close" class="reader-icon-btn" title="&#272;&#243;ng">
            <i data-lucide="x"></i>
          </button>
          <button id="reader-drawer-pin" class="reader-icon-btn" title="Ghim menu">
            <i data-lucide="pin"></i>
          </button>
        </div>
        <div class="reader-drawer-title">
          <i data-lucide="book-open"></i>
          <span id="reader-drawer-manga-title">@Model.Manga?.Title</span>
        </div>
        <div class="reader-drawer-chapter">
          <i data-lucide="file"></i>
          <span id="reader-drawer-chapter-title">Ch&#432;&#417;ng @Model.ChapterNumber</span>
        </div>
        <div class="reader-drawer-navrow">
          <button id="reader-drawer-page-prev" class="reader-drawer-step"><i data-lucide="chevron-left"></i></button>
          <button id="reader-drawer-page-select" class="reader-drawer-select">
            <small>Page</small>
            <span id="reader-drawer-page-label">1</span>
            <i data-lucide="chevron-down"></i>
          </button>
          <div id="reader-drawer-page-options" class="reader-drawer-options" style="display: none;"></div>
          <button id="reader-drawer-page-next" class="reader-drawer-step"><i data-lucide="chevron-right"></i></button>
        </div>
        <div class="reader-drawer-navrow">
          <button id="reader-drawer-chapter-prev" class="reader-drawer-step"><i data-lucide="chevron-left"></i></button>
          <button id="reader-drawer-chapter-select" class="reader-drawer-select">
            <small>Chapter</small>
            <span id="reader-drawer-chapter-label">Chapter @Model.ChapterNumber</span>
            <i data-lucide="chevron-down"></i>
          </button>
          <div id="reader-drawer-chapter-options" class="reader-drawer-options" style="display: none;"></div>
          <button id="reader-drawer-chapter-next" class="reader-drawer-step"><i data-lucide="chevron-right"></i></button>
        </div>
        <button id="reader-report-chapter" class="reader-drawer-wide-btn">Report Chapter</button>
        <div class="reader-drawer-divider"></div>
        <button id="reader-mode-long-strip" class="reader-drawer-wide-btn">
          <i data-lucide="panel-top"></i>
          <span>Long Strip</span>
        </button>
        <div class="reader-drawer-split">
          <button id="reader-fit-both" class="reader-drawer-wide-btn">
            <i data-lucide="expand"></i>
            <span>Fit Both</span>
          </button>
          <button class="reader-drawer-square-btn" title="Fit settings"><i data-lucide="settings"></i></button>
        </div>
        <button id="reader-direction-ltr" class="reader-drawer-wide-btn">
          <i data-lucide="circle-arrow-right"></i>
          <span>Left To Right</span>
        </button>
        <button id="reader-toggle-header" class="reader-drawer-wide-btn">
          <i data-lucide="square"></i>
          <span>Header Hidden</span>
        </button>
        <div class="reader-drawer-split">
          <button id="reader-progress-mode" class="reader-drawer-wide-btn">
            <i data-lucide="scan-line"></i>
            <span>Normal Progress</span>
          </button>
          <button class="reader-drawer-square-btn" title="Progress settings"><i data-lucide="settings"></i></button>
        </div>
        <button id="reader-settings-open" class="reader-drawer-wide-btn">
          <i data-lucide="settings"></i>
          <span>Reader Settings</span>
        </button>
      </aside>
      <button id="reader-drawer-rail" class="reader-drawer-rail" title="Menu &#273;&#7885;c truy&#7879;n" aria-label="Menu &#273;&#7885;c truy&#7879;n">
        <i data-lucide="menu"></i>
      </button>
      <div id="reader-settings-modal" class="reader-settings-modal" aria-hidden="true">
        <div class="reader-settings-backdrop"></div>
        <section class="reader-settings-dialog" role="dialog" aria-modal="true" aria-labelledby="reader-settings-title">
          <div class="reader-settings-head">
            <h2 id="reader-settings-title">Reader Settings</h2>
            <button id="reader-settings-close" class="reader-icon-btn" title="Close">
              <i data-lucide="x"></i>
            </button>
          </div>
          <div class="reader-settings-body">
            <nav class="reader-settings-tabs" aria-label="Reader Settings">
              <button class="reader-settings-tab active" data-reader-settings-tab="layout">Page Layout</button>
              <button class="reader-settings-tab" data-reader-settings-tab="image">Image fit</button>
              <button class="reader-settings-tab" data-reader-settings-tab="keybinds">Keybinds</button>
              <button class="reader-settings-tab" data-reader-settings-tab="behaviors">Behaviors</button>
            </nav>
            <div class="reader-settings-content">
              <div class="reader-settings-panel-page active" data-reader-settings-panel="layout">
                <div class="reader-setting-group">
                  <h3>Page Display Style</h3>
                  <div class="reader-segmented">
                    <button data-reader-display="single"><i data-lucide="file"></i><span>Single Page</span></button>
                    <button data-reader-display="double"><i data-lucide="book-open"></i><span>Double Page</span></button>
                    <button data-reader-display="long"><i data-lucide="panel-top"></i><span>Long Strip</span></button>
                    <button data-reader-display="wide"><i data-lucide="columns-2"></i><span>Wide Strip</span></button>
                  </div>
                </div>
                <div class="reader-setting-group">
                  <h3>Reading Direction</h3>
                  <div class="reader-segmented two">
                    <button data-reader-direction="ltr"><i data-lucide="circle-arrow-right"></i><span>Left To Right</span></button>
                    <button data-reader-direction="rtl"><i data-lucide="circle-arrow-left"></i><span>Right To Left</span></button>
                  </div>
                </div>
                <div class="reader-setting-group">
                  <h3>Header Visibility</h3>
                  <div class="reader-segmented two">
                    <button data-reader-header="hidden"><i data-lucide="square"></i><span>Header Hidden</span></button>
                    <button data-reader-header="shown"><i data-lucide="panel-top"></i><span>Header Shown</span></button>
                  </div>
                </div>
                <div class="reader-setting-group">
                  <h3>Progress Bar Style</h3>
                  <div class="reader-segmented three">
                    <button data-reader-progress="hidden"><i data-lucide="minus"></i><span>Progress Hidden</span></button>
                    <button data-reader-progress="lightbar"><i data-lucide="scan-line"></i><span>Progress Lightbar</span></button>
                    <button data-reader-progress="normal"><i data-lucide="scan-line"></i><span>Normal Progress</span></button>
                  </div>
                </div>
                <div class="reader-setting-group">
                  <h3>Reader Background Color</h3>
                  <div class="reader-segmented compact">
                    <button data-reader-background="white">White</button>
                    <button data-reader-background="black">Black</button>
                  </div>
                </div>
              </div>
              <div class="reader-settings-panel-page" data-reader-settings-panel="image">
                <div class="reader-setting-group">
                  <h3>Image Sizing</h3>
                  <button class="reader-check-row" data-reader-fit-toggle="width"><span class="reader-check-box"></span><span>Contain to width</span></button>
                  <button class="reader-check-row" data-reader-fit-toggle="height"><span class="reader-check-box"></span><span>Contain to height</span></button>
                  <button class="reader-check-row" data-reader-fit-toggle="none"><span class="reader-check-box"></span><span>Stretch small pages</span></button>
                </div>
                <div class="reader-setting-group">
                  <button class="reader-check-row" data-reader-fit-toggle="limit-width"><span class="reader-check-box"></span><span>Limit max width</span></button>
                  <button class="reader-check-row" data-reader-fit-toggle="limit-height"><span class="reader-check-box"></span><span>Limit max height</span></button>
                </div>
              </div>
              <div class="reader-settings-panel-page" data-reader-settings-panel="keybinds">
                <p class="reader-settings-help">Keybinds are active while reading. Inputs and search boxes are ignored.</p>
                <div id="reader-keybind-list" class="reader-keybind-list"></div>
                <button id="reader-reset-keybinds" class="reader-settings-reset"><i data-lucide="rotate-cw"></i><span>Reset All to Default Values</span></button>
              </div>
              <div class="reader-settings-panel-page" data-reader-settings-panel="behaviors">
                <div class="reader-setting-group">
                  <h3>Automatically advance chapter on last page</h3>
                  <div class="reader-segmented two">
                    <button data-reader-auto-advance="false">Disabled</button>
                    <button data-reader-auto-advance="true">Enabled</button>
                  </div>
                </div>
                <div class="reader-setting-group">
                  <h3>Turn pages by tapping</h3>
                  <div class="reader-segmented three">
                    <button data-reader-tap-mode="directional">Directional</button>
                    <button data-reader-tap-mode="forward">Always turn forward</button>
                    <button data-reader-tap-mode="never">Never</button>
                  </div>
                </div>
                <div class="reader-setting-group">
                  <h3>Turn pages by scrolling</h3>
                  <div class="reader-segmented four">
                    <button data-reader-scroll-turn="disabled">Disabled</button>
                    <button data-reader-scroll-turn="mouse">Mouse wheel</button>
                    <button data-reader-scroll-turn="keyboard">Keyboard</button>
                    <button data-reader-scroll-turn="both">Both</button>
                  </div>
                </div>
                <div class="reader-setting-group">
                  <h3>Double click to toggle fullscreen</h3>
                  <div class="reader-segmented two">
                    <button data-reader-double-fullscreen="false">Disabled</button>
                    <button data-reader-double-fullscreen="true">Enabled</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>

    <script>
      window.__CHAPTER_DETAIL__ = @Html.Raw(chapterJson);
      window.__MANGA_DETAIL__ = @Html.Raw(mangaChaptersJson);
    </script>
    <script src="/js/i18n.js?v=4.0"></script>
    <script src="/js/common-library.js?v=1.0"></script>
    <script src="/js/common-auth.js?v=1.0"></script>
    @await Html.PartialAsync("_ReportModal")
    <script src="/js/common.js?v=5.5"></script>
    <script src="/js/report-modal.js?v=1.0"></script>
    <script src="/js/reader-settings.js?v=1.1"></script>
    <script src="/js/reader.js?v=5.0"></script>
    <style>
      .reader-drawer-navrow { position: relative; }
      .reader-drawer-select.open [data-lucide], .reader-drawer-select.open svg { transform: rotate(180deg); }
      .reader-drawer-options { background-color: #3a3a3a; border: 1px solid rgba(255,255,255,.12); border-radius: 5px; box-shadow: 0 12px 30px rgba(0,0,0,.35); left: 42px; max-height: 220px; overflow-y: auto; position: absolute; right: 42px; top: 52px; z-index: 3; }
      .reader-drawer-option { background: transparent; border: 0; color: #fff; cursor: pointer; display: block; font-size: .82rem; padding: 9px 12px; text-align: left; width: 100%; }
      .reader-drawer-option:hover, .reader-drawer-option.active { background-color: #505050; }
      @@media (max-width: 768px) { .desktop-only { display: none !important; } }
    </style>
  </body>
</html>
