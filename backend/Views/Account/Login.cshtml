@{
    ViewData["Title"] = "\u0110\u0103ng nh\u1eadp";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card p-4">
                <h2 class="text-center fw-bold text-white mb-4"><i class="bi bi-person-fill me-2 text-warning"></i>&#272;&#259;ng nh&#7853;p</h2>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2">@ViewBag.Error</div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    @if (ViewBag.ReturnUrl != null)
                    {
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    }
                    <div class="mb-3">
                        <label class="form-label">T&#234;n &#273;&#259;ng nh&#7853;p ho&#7863;c email</label>
                        <input type="text" name="username" class="form-control" required autofocus autocomplete="username" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">M&#7853;t kh&#7849;u</label>
                        <input type="password" name="password" class="form-control" required autocomplete="current-password" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">&#272;&#259;ng nh&#7853;p</button>
                </form>

                <hr style="border-color:#2a2a4a;" class="my-3" />
                <p class="text-center text-secondary mb-0">
                    Ch&#432;a c&#243; t&#224;i kho&#7843;n? <a asp-action="Register">&#272;&#259;ng k&#253; ngay</a>
                </p>
            </div>
        </div>
    </div>
</div>
