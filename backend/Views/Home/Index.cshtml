@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MangaNPK - Đọc Truyện Tranh Online</title>
    <link rel="stylesheet" href="/css/style.css?v=4.9" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body>
    <div id="root">
      @await Html.PartialAsync("_Header")
      @await Html.PartialAsync("_Sidebar")
      @await Html.PartialAsync("_AuthModal")

      <main id="main-layout" style="flex: 1; display: flex; flex-direction: column; width: 100%;">
        <section style="width: 100%; position: relative; overflow: hidden; background-color: var(--bg-darker, #0B0E14); margin-top: -70px; margin-bottom: 30px;">
          <div id="featured-slider-container" style="width: 100%;"></div>
        </section>

        <div class="container" style="position: relative; width: 100%;">

          <!-- Filters -->
          <div class="glass-card" style="padding: 20px 30px; border-radius: var(--radius-md); display: flex; align-items: center; gap: 15px; margin-bottom: 30px;">
            <div style="display: flex; gap: 8px; background-color: var(--bg-darker, #0B0E14); padding: 4px; border-radius: var(--radius-sm); border: 1px solid var(--border-subtle);">
              <button class="type-filter-btn active" data-type="All" style="padding: 8px 18px; border-radius: 4px; font-size: 0.95rem; font-weight: 700; transition: all 0.2s; background-color: var(--accent-primary); color: white;" data-i18n="filter.all">T&#7845;t c&#7843;</button>
              <button class="type-filter-btn" data-type="Manga" style="padding: 8px 18px; border-radius: 4px; font-size: 0.95rem; font-weight: 700; transition: all 0.2s; background-color: transparent; color: var(--text-muted);" data-i18n="filter.typeManga">Manga</button>
              <button class="type-filter-btn" data-type="Manhwa" style="padding: 8px 18px; border-radius: 4px; font-size: 0.95rem; font-weight: 700; transition: all 0.2s; background-color: transparent; color: var(--text-muted);" data-i18n="filter.typeManhwa">Manhwa</button>
              <button class="type-filter-btn" data-type="Manhua" style="padding: 8px 18px; border-radius: 4px; font-size: 0.95rem; font-weight: 700; transition: all 0.2s; background-color: transparent; color: var(--text-muted);" data-i18n="filter.typeManhua">Manhua</button>
            </div>
          </div>

          <!-- Manga carousel -->
          <div class="header md:overflow-hidden">
            <div class="flex justify-between items-center text-2xl mb-4">
              <a href="/manga" class="link section-title" data-i18n="section.recommended">Gợi Ý Cho Bạn</a>
              <a href="/manga" class="rounded custom-opacity relative md-btn flex items-center px-3 overflow-hidden accent text rounded-full !px-0" aria-label="Xem danh sách truyện gợi ý" style="min-height: 2.5rem; min-width: 2.5rem;">
                <span class="flex relative items-center justify-center font-medium select-none w-full pointer-events-none" style="justify-content: center;">
                  <i data-lucide="chevron-right" style="width: 22px; height: 22px;"></i>
                </span>
              </a>
            </div>

            <div id="manga-loading-placeholder" style="display: none; justify-content: center; align-items: center; padding: 60px 0;">
              <div class="loader"></div>
            </div>

            <div id="manga-swiper-view" style="position: relative;">
              <div class="swiper manga-swiper fill-width">
                <div class="swiper-wrapper" id="manga-grid-container"></div>
                <div class="swiper-button-next"></div>
                <div class="swiper-button-prev"></div>
                <div class="swiper-pagination"></div>
              </div>
            </div>
          </div>

          <!-- Latest Updates -->
          <section class="latest-updates-section">
            <h3 class="section-title" style="margin-bottom: 16px;" data-i18n="section.latestUpdates">
              <i data-lucide="clock" style="width: 18px; height: 18px; display: inline-block; vertical-align: middle; margin-right: 8px;"></i>
              Latest Updates
            </h3>
            <div class="latest-updates-panel">
              <div id="latest-updates-container"></div>
            </div>
          </section>
        </div>
      </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="/js/i18n.js?v=4.0"></script>
    <script src="/js/common-library.js?v=1.0"></script>
    <script src="/js/common-auth.js?v=1.0"></script>
<script src="/js/common.js?v=5.5"></script>
    <script src="/js/index.js?v=3.8"></script>
    <style>
      @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
      .dropdown-item { padding: 8px 16px; font-size: 0.85rem; color: var(--text-main); cursor: pointer; transition: background-color 0.15s, color 0.15s; }
      .dropdown-item:hover { background-color: rgba(255,255,255,0.05); color: white; }
      .dropdown-item.active { color: #fff; background-color: var(--accent-primary); font-weight: 600; }
      .manga-swiper { padding: 8px 4px 40px 4px !important; }
      .manga-swiper .swiper-slide { height: auto; }
      .swiper-pagination-bullet { background: var(--text-muted) !important; opacity: 0.5; }
      .swiper-pagination-bullet-active { background: var(--accent-primary) !important; opacity: 1; }
    </style>
  </body>
</html>
