@model MangaNPK.Models.Chapter
@{
    Layout = null;
    var allChapters = ViewBag.AllChapters as List<MangaNPK.Models.Chapter> ?? new();
    var chapterJson = System.Text.Json.JsonSerializer.Serialize(new {
        id = Model.Id,
        mangaId = Model.MangaId,
        mangaTitle = Model.Manga?.Title ?? "",
        chapterNumber = Model.ChapterNumber,
        title = Model.Title,
        uploadedAt = Model.UploadedAt,
        pages = Model.Pages.Select(p => new { id = p.Id, pageNumber = p.PageNumber, imageUrl = p.ImageUrl }),
        prevChapterId = ViewBag.PrevChapterId,
        nextChapterId = ViewBag.NextChapterId
    });
    var mangaChaptersJson = System.Text.Json.JsonSerializer.Serialize(new {
        id = Model.MangaId,
        chapters = allChapters.Select(c => new { id = c.Id, chapterNumber = c.ChapterNumber, title = c.Title })
    });
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Manga?.Title - Chương @Model.ChapterNumber - MangaNPK</title>
    <link rel="stylesheet" href="/css/style.css?v=3.0" />
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body style="background-color: #090B0F;">
    <div id="root">
      <header id="global-header" class="glass" style="position: absolute; top: 0; left: 0; right: 0; z-index: 1000; transition: transform 0.3s ease; width: 100%;">
        <div style="display: flex; align-items: center; justify-content: space-between; height: 60px; padding: 0 20px;">
          <div style="display: flex; align-items: center; gap: 15px;">
            <button id="sidebar-toggle-btn" style="color: var(--text-main); display: flex; align-items: center; cursor: pointer; background: none; border: none;" title="Menu">
              <i data-lucide="menu" style="width: 22px; height: 22px;"></i>
            </button>
            <div id="logo-btn" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
              <div style="width: 32px; height: 32px; border-radius: 6px; background-color: #FF8C00; display: flex; align-items: center; justify-content: center;">
                <i data-lucide="book-open" style="width: 16px; height: 16px; color: white;"></i>
              </div>
              <span style="font-size: 1.15rem; font-weight: 800; letter-spacing: -0.02em; color: white; display: inline-block;">Manga<span style="color: #FF8C00;">NPK</span></span>
            </div>
            <div style="width: 1px; height: 20px; background-color: rgba(255,255,255,0.1); margin: 0 5px;" class="desktop-only"></div>
            <div id="reader-manga-title-breadcrumb" style="font-size: 0.9rem; font-weight: 700; color: #FF8C00; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; cursor: pointer;" class="desktop-only">@Model.Manga?.Title</div>
          </div>
          <div style="display: flex; align-items: center; gap: 8px;">
            <button id="btn-prev-chap" class="btn btn-secondary" style="border-radius: 4px; width: 34px; height: 34px; padding: 0; display: flex; align-items: center; justify-content: center;" title="Chương trước">
              <i data-lucide="chevron-left" style="width: 18px; height: 18px;"></i>
            </button>
            <div style="position: relative;" id="chapter-select-dropdown-container">
              <div id="chapter-select-trigger" style="display: flex; align-items: center; gap: 8px; background-color: #1A1D24; border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; height: 34px; padding: 0 12px; cursor: pointer; user-select: none; font-size: 0.85rem; font-weight: 700;">
                <span id="current-chapter-label">Chương @Model.ChapterNumber</span>
                <i data-lucide="chevron-left" style="width: 14px; height: 14px; transform: rotate(-90deg); color: var(--text-muted);"></i>
              </div>
              <div id="chapter-select-options" class="glass" style="display: none; position: absolute; top: 40px; left: 50%; transform: translateX(-50%); width: 220px; max-height: 250px; overflow-y: auto; border-radius: var(--radius-sm); z-index: 100; box-shadow: var(--shadow-md); padding: 4px 0;"></div>
            </div>
            <div style="position: relative;" id="page-select-dropdown-container">
              <div id="page-select-trigger" style="display: flex; align-items: center; gap: 8px; background-color: #1A1D24; border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; height: 34px; padding: 0 12px; cursor: pointer; user-select: none; font-size: 0.85rem; font-weight: 700;">
                <span id="current-page-label">Trang -- / --</span>
                <i data-lucide="chevron-left" style="width: 14px; height: 14px; transform: rotate(-90deg); color: var(--text-muted);"></i>
              </div>
              <div id="page-select-options" class="glass" style="display: none; position: absolute; top: 40px; left: 50%; transform: translateX(-50%); width: 140px; max-height: 250px; overflow-y: auto; border-radius: var(--radius-sm); z-index: 100; box-shadow: var(--shadow-md); padding: 4px 0;"></div>
            </div>
            <button id="btn-next-chap" class="btn btn-secondary" style="border-radius: 4px; width: 34px; height: 34px; padding: 0; display: flex; align-items: center; justify-content: center;" title="Chương sau">
              <i data-lucide="chevron-right" style="width: 18px; height: 18px;"></i>
            </button>
          </div>
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="position: relative;" id="reader-settings-dropdown-container">
              <button id="reader-settings-btn" class="btn btn-secondary" style="border-radius: 4px; width: 34px; height: 34px; padding: 0; display: flex; align-items: center; justify-content: center;" title="Cài đặt">
                <i data-lucide="settings" style="width: 18px; height: 18px;"></i>
              </button>
              <div id="reader-settings-options" class="glass" style="display: none; position: absolute; top: 40px; right: 0; width: 260px; border-radius: var(--radius-sm); z-index: 100; box-shadow: var(--shadow-lg); padding: 16px; border: 1px solid rgba(255,255,255,0.08);">
                <h4 style="font-size: 0.85rem; font-weight: 700; color: white; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.05em;">Cấu hình đọc</h4>
                <div class="settings-group" style="margin-bottom: 15px;">
                  <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 6px; font-weight: 600;">Chế độ đọc:</div>
                  <div style="display: flex; gap: 6px; background-color: #0B0E14; padding: 3px; border-radius: 4px; border: 1px solid rgba(255,255,255,0.05);">
                    <button id="opt-mode-scroll" style="flex: 1; padding: 6px 0; font-size: 0.8rem; font-weight: 700; border-radius: 3px; text-align: center; cursor: pointer; border: none;">Cuộn dọc</button>
                    <button id="opt-mode-slide" style="flex: 1; padding: 6px 0; font-size: 0.8rem; font-weight: 700; border-radius: 3px; text-align: center; cursor: pointer; border: none;">Từng trang</button>
                  </div>
                </div>
                <div class="settings-group">
                  <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 6px; font-weight: 600;">Kích thước ảnh:</div>
                  <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px;">
                    <button class="opt-fit-btn" data-fit="both" style="padding: 6px 0; font-size: 0.75rem; font-weight: 700; background-color: #1C1F26; border-radius: 4px; text-align: center; border: none; cursor: pointer;">Tự động</button>
                    <button class="opt-fit-btn" data-fit="width" style="padding: 6px 0; font-size: 0.75rem; font-weight: 700; background-color: #1C1F26; border-radius: 4px; text-align: center; border: none; cursor: pointer;">Đầy chiều ngang</button>
                    <button class="opt-fit-btn" data-fit="height" style="padding: 6px 0; font-size: 0.75rem; font-weight: 700; background-color: #1C1F26; border-radius: 4px; text-align: center; border: none; cursor: pointer;">Đầy chiều dọc</button>
                    <button class="opt-fit-btn" data-fit="none" style="padding: 6px 0; font-size: 0.75rem; font-weight: 700; background-color: #1C1F26; border-radius: 4px; text-align: center; border: none; cursor: pointer;">Gốc (100%)</button>
                  </div>
                </div>
              </div>
            </div>
            <div id="header-user-area" style="display: flex; align-items: center;"></div>
          </div>
        </div>
      </header>

      @await Html.PartialAsync("_Sidebar")
      @await Html.PartialAsync("_AuthModal")

      <main id="main-layout" style="flex: 1; display: flex; flex-direction: column; width: 100%; padding-top: 60px;">
        <div id="reader-loading-spinner" style="display: none;"></div>
        <div id="reader-main-content" style="display: block; width: 100%; position: relative; flex: 1;">
          <div style="text-align: center; padding: 24px 16px 12px 16px; background-color: rgba(0,0,0,0.2);">
            <h2 id="reader-manga-title-h2" style="font-size: 1.35rem; font-weight: 800; color: white; margin-bottom: 4px;">@Model.Manga?.Title</h2>
            <p id="reader-chapter-title-p" style="font-size: 0.9rem; color: var(--text-muted);">Chương @Model.ChapterNumber@(string.IsNullOrEmpty(Model.Title) || Model.Title == $"Chương {Model.ChapterNumber}" ? "" : ": " + Model.Title)</p>
          </div>
          <div style="height: 1px; background-color: rgba(255,255,255,0.08); width: 100%;" id="reader-divider-line"></div>
          <div id="reader-viewer-pane" style="position: relative; width: 100%; display: flex; flex-direction: column; align-items: center; margin: 0 auto; user-select: none;">
            <div id="reader-navigation-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 10; display: flex; pointer-events: none;">
              <div id="nav-zone-left" style="width: 50%; height: 100%; pointer-events: auto;"></div>
              <div id="nav-zone-right" style="width: 50%; height: 100%; pointer-events: auto;"></div>
            </div>
            <div id="viewer-scroll-container" style="display: flex; flex-direction: column; width: 100%; gap: 12px; align-items: center; padding: 20px 0;"></div>
            <div id="viewer-slide-container" style="display: none; width: 100%; justify-content: center; align-items: center; min-height: 70vh; padding: 20px 0;"></div>
          </div>
          <div style="background-color: #111319; border-top: 1px solid rgba(255,255,255,0.05); padding: 24px; display: flex; justify-content: center; align-items: center; gap: 15px;">
            <button id="btn-bottom-prev" class="btn btn-secondary" style="border-radius: 20px; padding: 8px 24px; font-weight: 700;">
              <i data-lucide="chevron-left" style="width: 16px; height: 16px;"></i> Chương Trước
            </button>
            <button id="btn-bottom-next" class="btn btn-primary" style="border-radius: 20px; padding: 8px 24px; font-weight: 700;">
              Chương Tiếp Theo <i data-lucide="chevron-right" style="width: 16px; height: 16px;"></i>
            </button>
          </div>
        </div>
      </main>
    </div>

    <script>
      window.__CHAPTER_DETAIL__ = @Html.Raw(chapterJson);
      window.__MANGA_DETAIL__ = @Html.Raw(mangaChaptersJson);
    </script>
    <script src="/js/common.js?v=3.0"></script>
    <script src="/js/reader.js?v=3.0"></script>
    <style>
      @@media (max-width: 768px) { .desktop-only { display: none !important; } }
    </style>
  </body>
</html>
