@model MangaNPK.Models.Manga
@{
    Layout = null;
    var chaptersJson = System.Text.Json.JsonSerializer.Serialize(Model.Chapters?.OrderByDescending(c => c.ChapterNumber).Select(c => new {
        id = c.Id, chapterNumber = c.ChapterNumber, title = c.Title, uploadedAt = c.UploadedAt
    }));
    var genresJson = System.Text.Json.JsonSerializer.Serialize(Model.MangaGenres?.Select(g => new { id = g.GenreId, name = g.Genre.Name }));
    var authorsJson = System.Text.Json.JsonSerializer.Serialize(Model.MangaAuthors?.Select(a => new { name = a.Author.Name, role = a.Role }));
    var recsJson = System.Text.Json.JsonSerializer.Serialize((ViewBag.Recommendations as List<MangaNPK.Models.Manga> ?? new()).Select(r => new {
        id = r.Id, title = r.Title, coverUrl = r.CoverUrl, type = r.Type.ToString(), status = r.Status.ToString(), releaseYear = r.ReleaseYear
    }));
    var mangaJson = System.Text.Json.JsonSerializer.Serialize(new {
        id = Model.Id, title = Model.Title, alternativeTitle = Model.AlternativeTitle,
        description = Model.Description, coverUrl = Model.CoverUrl,
        type = Model.Type.ToString(), status = Model.Status.ToString(),
        demographic = (int)Model.Demographic, format = (int)Model.Format,
        releaseYear = Model.ReleaseYear, createdAt = Model.CreatedAt, viewCount = Model.ViewCount,
        contentWarnings = Model.ContentWarnings,
        genres = Model.MangaGenres?.Select(g => new { id = g.GenreId, name = g.Genre.Name }),
        themes = Model.MangaThemes?.Select(t => new { id = t.ThemeId, name = t.Theme.Name }),
        authors = Model.MangaAuthors?.Select(a => new { name = a.Author.Name, role = a.Role }),
        chapters = Model.Chapters?.OrderByDescending(c => c.ChapterNumber).Select(c => new { id = c.Id, chapterNumber = c.ChapterNumber, title = c.Title, uploadedAt = c.UploadedAt })
    });
}
<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title - MangaNPK</title>
    <link rel="stylesheet" href="/css/style.css?v=4.9" />
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body class="detail-page">
    <div id="root">
      @await Html.PartialAsync("_Header")
      @await Html.PartialAsync("_Sidebar")
      @await Html.PartialAsync("_AuthModal")

      <main id="main-layout" style="flex: 1; display: flex; flex-direction: column; width: 100%;">
        <div id="detail-loading-spinner" style="display: none;"></div>
        <div id="detail-main-content" style="display: block;">
          <div id="detail-banner-area" class="detail-banner">
            <div id="banner-bg-container"></div>
            <div class="container">
              <div class="detail-banner-content">
                <div class="detail-cover" id="manga-detail-cover-container"></div>
                <div class="detail-info">
                  <div style="display: flex; gap: 8px; flex-wrap: wrap;" id="manga-type-badge-container"></div>
                  <h1 class="detail-title" id="manga-detail-title">@Model.Title</h1>
                  <div class="detail-alt-title" id="manga-detail-alt-title">@Model.AlternativeTitle</div>
                  <div class="detail-author" id="manga-detail-authors"></div>
                  <div class="detail-actions">
                    <button class="btn-action primary" id="btn-library-status">
                      <i data-lucide="library" style="width: 16px; height: 16px;"></i>
                      <span>Add To Library</span>
                    </button>
                    <button class="btn-action secondary" id="btn-bookmark-manga">
                      <i data-lucide="star" style="width: 16px; height: 16px;"></i>
                    </button>
                    <button class="btn-action secondary" id="btn-add-to-list" style="display: none;">
                      <i data-lucide="list-plus" style="width: 16px; height: 16px;"></i> Add to list
                    </button>
                    <div class="detail-rating-control" id="rating-control">
                      <button class="btn-action secondary" id="rating-menu-btn" type="button">
                        <i data-lucide="star" style="width: 16px; height: 16px;"></i>
                        <span id="rating-menu-label">Đánh giá</span>
                      </button>
                      <div class="detail-rating-menu" id="rating-score-menu" style="display: none;"></div>
                    </div>
                    <button class="btn-action secondary" id="btn-continue-reading">
                      <i data-lucide="book-open" style="width: 16px; height: 16px;"></i> Continue Reading
                    </button>
                    <button class="btn-action secondary" id="btn-report-manga">
                      <i data-lucide="flag" style="width: 16px; height: 16px;"></i> Report
                    </button>
                  </div>
                  <div class="detail-tags" id="manga-genres-tags"></div>
                  <div class="detail-stats-row">
                    <span><i data-lucide="star" style="width: 14px; height: 14px;"></i><strong id="detail-rating-average">-</strong></span>
                    <span><i data-lucide="eye" style="width: 14px; height: 14px;"></i><strong id="detail-view-count">@Model.ViewCount</strong></span>
                    <span><i data-lucide="book-open" style="width: 14px; height: 14px;"></i><strong id="detail-chapter-count">@((Model.Chapters?.Count) ?? 0)</strong></span>
                    <span><i data-lucide="message-square" style="width: 14px; height: 14px;"></i><strong id="detail-rating-count">0</strong></span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="container" style="margin-top: 30px; margin-bottom: 50px;">
            <div style="margin-bottom: 24px;">
              <a href="/" class="btn btn-secondary" style="border-radius: 20px; display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; font-size: 0.85rem;">
                <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Quay l&#7841;i trang ch&#7911;
              </a>
            </div>
            <div class="detail-description-panel">
                  <p id="manga-description-text" data-i18n="common.noData">Chưa có mô tả.</p>
            </div>
            <div class="detail-content">
              <div class="detail-sidebar">
                <div class="detail-sidebar-section"><h4 data-i18n="detail.status">Tình trạng</h4><div class="value" id="manga-status-val"></div></div>
                <div class="detail-sidebar-section"><h4 data-i18n="detail.releaseYear">Năm phát hành</h4><div class="value" id="manga-release-year-val"></div></div>
                <div class="detail-sidebar-section"><h4 data-i18n="detail.demographic">Demographic</h4><div id="manga-demographic-badge"></div></div>
                <div class="detail-sidebar-section"><h4 data-i18n="detail.format">Định dạng (Format)</h4><div id="manga-format-badge"></div></div>
                <div class="detail-sidebar-section"><h4 data-i18n="detail.createdDate">Ng&#224;y kh&#7903;i t&#7841;o</h4><div class="value" id="manga-created-date-val"></div></div>
              </div>
              <div class="detail-main">
                <div class="detail-tabs">
              <button class="tab active" data-tab="chapters" data-i18n="detail.chapters">Chương truyện</button>
              <button class="tab" data-tab="comments" data-i18n="detail.comments">Bình luận</button>
              <button class="tab" data-tab="art" data-i18n="detail.art">Hình ảnh / Art</button>
              <button class="tab" data-tab="recommendations" data-i18n="detail.recommendations">Gợi ý tương tự</button>
                </div>
                <div id="tab-content-chapters" class="tab-pane animate-fade-in">
                  <div class="detail-chapter-toolbar">
                  <h3 style="font-size: 1.15rem; font-weight: 700; color: white; margin: 0;" id="chapters-count-label" data-i18n="detail.chapterList">Danh sách chương</h3>
                    <button class="btn btn-secondary" id="btn-sort-chapters" style="border-radius: 4px; padding: 6px 12px; font-size: 0.8rem; display: flex; align-items: center; gap: 6px;">
                    <i data-lucide="layers" style="width: 14px; height: 14px;"></i> <span data-i18n="detail.newestFirst">Mới nhất trước</span>
                    </button>
                  </div>
                  <div id="chapters-list-container" class="detail-chapter-list"></div>
                  <div id="chapters-pagination" class="detail-chapter-pagination"></div>
                </div>
                <div id="tab-content-comments" class="tab-pane animate-fade-in" style="display: none;">
                  <div id="comment-form-container" class="glass-card" style="padding: 20px; border-radius: var(--radius-md); margin-bottom: 20px; display: none;">
                    <div style="display: flex; gap: 12px;">
                      <div style="width: 40px; height: 40px; border-radius: 50%; background-color: var(--bg-input); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <i data-lucide="user" style="width: 20px; height: 20px; color: var(--text-muted);"></i>
                      </div>
                      <div style="flex: 1; display: flex; flex-direction: column; gap: 12px;">
                        <textarea
                          id="comment-input"
                          class="form-control"
                          data-i18n="comments.placeholder"
                          data-i18n-attr="placeholder"
                              placeholder="Viết bình luận của bạn..."
                          rows="3"
                          style="resize: vertical; min-height: 80px;"
                        ></textarea>
                        <div style="display: flex; justify-content: flex-end;">
                          <button id="btn-submit-comment" class="btn btn-primary" style="border-radius: 20px; padding: 8px 20px; font-size: 0.85rem; font-weight: 700;">
                        <i data-lucide="send" style="width: 14px; height: 14px;"></i> <span data-i18n="comments.send">Gửi bình luận</span>
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div id="comment-login-prompt" class="glass-card" style="padding: 20px; border-radius: var(--radius-md); margin-bottom: 20px; text-align: center;">
                    <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 12px;">
                      <i data-lucide="lock" style="width: 16px; height: 16px; vertical-align: middle;"></i>
                      <span data-i18n="comments.loginRequired">Đăng nhập để bình luận</span>
                    </p>
                    <button id="comment-login-btn" class="btn btn-secondary" style="border-radius: 20px; padding: 8px 20px; font-size: 0.85rem;">
                      <span data-i18n="auth.login">Đăng nhập</span>
                    </button>
                  </div>

                  <div id="comments-loading" style="display: none; justify-content: center; padding: 40px;">
                    <div class="loader"></div>
                  </div>

                  <div id="comments-list" style="display: none; flex-direction: column; gap: 16px;"></div>

                  <div id="comments-empty" style="display: none; text-align: center; padding: 40px; color: var(--text-muted);">
                    <i data-lucide="message-square" style="width: 48px; height: 48px; margin-bottom: 12px; opacity: 0.5;"></i>
                    <p data-i18n="comments.empty">Chưa có bình luận nào. Hãy là người đầu tiên bình luận!</p>
                  </div>
                </div>
                <div id="tab-content-art" class="tab-pane animate-fade-in" style="display: none;">
                  <div class="glass-card" style="padding: 24px; border-radius: var(--radius-md); text-align: center;">
                    <i data-lucide="file-text" style="width: 36px; height: 36px; color: var(--text-muted); margin-bottom: 12px;"></i>
              <p style="color: var(--text-muted); font-size: 0.9rem;">Hình ảnh minh hoạ chưa được tải lên.</p>
                  </div>
                </div>
                <div id="tab-content-recommendations" class="tab-pane animate-fade-in" style="display: none;">
                  <div class="manga-grid" id="recommendations-grid-container" style="grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <div id="add-to-list-modal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.75); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; z-index: 2000; padding: 20px;">
      <div class="glass-card" style="width: 100%; max-width: 380px; padding: 24px; border-radius: var(--radius-md);">
        <h3 style="font-size: 1rem; font-weight: 800; color: var(--text-bright); margin-bottom: 16px;" data-i18n="lists.addToList">Thêm vào danh sách</h3>
        <div id="add-to-list-options" style="display: flex; flex-direction: column; gap: 8px; max-height: 300px; overflow-y: auto; margin-bottom: 16px;"></div>
        <div style="text-align: center; margin-bottom: 12px;">
          <button id="btn-create-list-from-detail" class="btn btn-secondary" style="font-size: 0.8rem; display: flex; align-items: center; gap: 4px; margin: 0 auto;">
            <i data-lucide="plus" style="width: 14px; height: 14px;"></i>
              <span data-i18n="lists.newList">Danh sách mới</span>
          </button>
        </div>
          <button id="btn-close-list-modal" class="btn btn-secondary" style="width: 100%;" data-i18n="common.close">Đóng</button>
      </div>
    </div>

    <div id="add-to-library-modal" class="add-library-modal" aria-hidden="true">
      <div class="add-library-backdrop"></div>
      <section class="add-library-dialog" role="dialog" aria-modal="true">
        <div class="add-library-head">
          <h2>Add To Library</h2>
          <button id="add-library-close" class="reader-icon-btn" type="button" title="Close"><i data-lucide="x"></i></button>
        </div>
        <div class="add-library-body">
          <img id="add-library-cover" class="add-library-cover" src="@Model.CoverUrl" alt="@Model.Title" />
          <div class="add-library-main">
            <h3 id="add-library-title">@Model.Title</h3>
            <label>Reading Status</label>
            <div class="add-library-status-row">
              <div class="add-library-select-wrap">
                <button id="add-library-status-select" class="add-library-select" type="button">
                  <small>Reading Status</small>
                  <span id="add-library-selected-label">Reading</span>
                  <i data-lucide="chevron-down"></i>
                </button>
                <div id="add-library-status-menu" class="add-library-status-menu"></div>
              </div>
              <button id="add-library-status-icon" class="add-library-icon" type="button"><i data-lucide="bell"></i></button>
            </div>
          </div>
        </div>
        <div class="add-library-actions">
          <button id="add-library-cancel" class="add-library-cancel" type="button">Cancel</button>
          <button id="add-library-submit" class="add-library-submit" type="button">Add</button>
        </div>
      </section>
    </div>

    <script>
    // Inject server data — replaces fetch API calls
      window.__MANGA_DETAIL__ = @Html.Raw(mangaJson);
      window.__RECOMMENDATIONS__ = @Html.Raw(recsJson);
    </script>
    <script src="/js/i18n.js?v=4.0"></script>
    <script src="/js/common-library.js?v=1.0"></script>
    <script src="/js/common-auth.js?v=1.0"></script>
<script src="/js/common.js?v=5.5"></script>
    <script src="/js/detail-taxonomy.js?v=1.0"></script>
    <script src="/js/detail-lists.js?v=1.0"></script>
    <script src="/js/detail.js?v=4.7"></script>
    <script src="/js/detail-comments.js?v=3.1"></script>
    <script src="/js/detail-rating.js?v=3.4"></script>
    <style>
      .chapter-item-hover:hover { background-color: var(--bg-card-hover) !important; border-color: rgba(255,255,255,0.12) !important; }
      .rec-card { cursor: pointer; transition: transform 0.2s, border-color 0.2s, background-color 0.2s; }
      .rec-card:hover { transform: translateY(-4px); border-color: rgba(255,255,255,0.15) !important; background-color: var(--bg-card-hover) !important; }
    </style>
  </body>
</html>
